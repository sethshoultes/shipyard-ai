{
  "name": "@great-minds/memory-store",
  "version": "1.0.0",
  "description": "Vector store for Great Minds agency memory system — SQLite + embeddings",
  "type": "module",
  "bin": {
    "memory": "./bin/memory"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli.ts",
    "import": "tsx src/cli.ts import --dir ../memory --rounds ../rounds",
    "export": "tsx src/cli.ts export"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
