{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "whisper/transcript",
	"title": "Whisper Transcript",
	"category": "media",
	"icon": "microphone",
	"description": "Upload audio or video and generate a synchronized, clickable transcript.",
	"keywords": [ "audio", "video", "transcript", "caption" ],
	"version": "1.0.0",
	"textdomain": "whisper",
	"editorScript": "file:./build/block.js",
	"editorStyle": "file:./build/block.css",
	"style": "file:./build/block.css",
	"script": "file:./build/frontend.js",
	"attributes": {
		"audioUrl": {
			"type": "string",
			"default": ""
		},
		"transcript": {
			"type": "array",
			"default": []
		},
		"jobId": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"html": false
	}
}
