</style>

<script define:vars={{ memberEmail, groupId: group?.id || '', isOwner }}>
	// Only run client-side JS if there's a group and user is owner
	if (typeof document !== 'undefined' && groupId) {
		document.addEventListener('DOMContentLoaded', () => {
			// --- Invite modal ---
			const inviteBtn = document.getElementById('groupInviteBtn');
			const inviteModal = document.getElementById('inviteModal');
			const inviteClose = document.getElementById('inviteModalClose');
			const generateBtn = document.getElementById('generateInviteBtn');
			const inviteResult = document.getElementById('inviteResult');
			const inviteLinkOutput = document.getElementById('inviteLinkOutput');
			const copyBtn = document.getElementById('copyInviteBtn');
			const inviteEmailInput = document.getElementById('inviteEmailInput');
			const inviteSuccessMsg = document.getElementById('inviteSuccessMsg');

			function openInviteModal() {
				if (inviteModal) {
					inviteModal.hidden = false;
					if (inviteEmailInput) inviteEmailInput.focus();
				}
			}

			function closeInviteModal() {
				if (inviteModal) {
					inviteModal.hidden = true;
					// Reset state
					if (inviteEmailInput) inviteEmailInput.value = '';
					if (inviteResult) inviteResult.hidden = true;
					if (inviteLinkOutput) inviteLinkOutput.value = '';
					if (inviteSuccessMsg) inviteSuccessMsg.textContent = '';
				}
			}

			if (inviteBtn) inviteBtn.addEventListener('click', openInviteModal);
			if (inviteClose) inviteClose.addEventListener('click', closeInviteModal);

			// Close on overlay click
			if (inviteModal) {
				inviteModal.addEventListener('click', (e) => {
					if (e.target === inviteModal) closeInviteModal();
				});
			}

			// Generate invite link
			if (generateBtn) {
				generateBtn.addEventListener('click', async () => {
					generateBtn.disabled = true;
					generateBtn.textContent = 'Generating...';

					try {
						const email = inviteEmailInput ? inviteEmailInput.value.trim() : '';
						const response = await fetch('/_emdash/api/plugins/membership/memberGroupInvite', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							credentials: 'include',
							body: JSON.stringify({
								ownerEmail: memberEmail,
								groupId: groupId,
								email: email,
							}),
						});

						const data = await response.json();

						if (response.ok && data.success) {
							if (inviteLinkOutput) inviteLinkOutput.value = data.inviteLink || '';
							if (inviteSuccessMsg) inviteSuccessMsg.textContent = data.message || 'Invite created!';
							if (inviteResult) inviteResult.hidden = false;
						} else {
							alert(data.error || 'Failed to generate invite link');
						}
					} catch (err) {
						alert('Error generating invite link. Please try again.');
					} finally {
						generateBtn.disabled = false;
						generateBtn.textContent = 'Generate Invite Link';
					}
				});
			}

			// Copy to clipboard
			if (copyBtn) {
				copyBtn.addEventListener('click', async () => {
					const link = inviteLinkOutput ? inviteLinkOutput.value : '';
					if (!link) return;

					try {
						await navigator.clipboard.writeText(link);
						copyBtn.textContent = 'Copied!';
						setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
					} catch {
						// Fallback: select the text
						if (inviteLinkOutput) {
							inviteLinkOutput.select();
							document.execCommand('copy');
							copyBtn.textContent = 'Copied!';
							setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
						}
					}
				});
			}

			// --- Remove confirmation modal ---
			const removeModal = document.getElementById('removeModal');
			const removeClose = document.getElementById('removeModalClose');
			const removeCancelBtn = document.getElementById('removeCancelBtn');
			const removeConfirmBtn = document.getElementById('removeConfirmBtn');
			const removeEmailDisplay = document.getElementById('removeEmailDisplay');
			let pendingRemoveEmail = '';

			function openRemoveModal(email) {
				pendingRemoveEmail = email;
				if (removeEmailDisplay) removeEmailDisplay.textContent = email;
				if (removeModal) removeModal.hidden = false;
			}

			function closeRemoveModal() {
				if (removeModal) removeModal.hidden = true;
				pendingRemoveEmail = '';
			}

			if (removeClose) removeClose.addEventListener('click', closeRemoveModal);
			if (removeCancelBtn) removeCancelBtn.addEventListener('click', closeRemoveModal);

			if (removeModal) {
				removeModal.addEventListener('click', (e) => {
					if (e.target === removeModal) closeRemoveModal();
				});
			}

			// Wire up all remove buttons
			document.querySelectorAll('.group-mgmt__remove-btn').forEach((btn) => {
				btn.addEventListener('click', () => {
					const email = btn.getAttribute('data-email');
					if (email) openRemoveModal(email);
				});
			});

			// Confirm remove
			if (removeConfirmBtn) {
				removeConfirmBtn.addEventListener('click', async () => {
					if (!pendingRemoveEmail) return;

					removeConfirmBtn.disabled = true;
					removeConfirmBtn.textContent = 'Removing...';

					try {
						const response = await fetch('/_emdash/api/plugins/membership/memberGroupRemove', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							credentials: 'include',
							body: JSON.stringify({
								ownerEmail: memberEmail,
								groupId: groupId,
								email: pendingRemoveEmail,
							}),
						});

						const data = await response.json();

						if (response.ok && data.success) {
							closeRemoveModal();
							// Reload to reflect changes
							window.location.reload();
						} else {
							alert(data.error || 'Failed to remove member');
						}
					} catch (err) {
						alert('Error removing member. Please try again.');
					} finally {
						removeConfirmBtn.disabled = false;
						removeConfirmBtn.textContent = 'Remove Member';
					}
				});
			}

			// Escape key closes modals
			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') {
					if (inviteModal && !inviteModal.hidden) closeInviteModal();
					if (removeModal && !removeModal.hidden) closeRemoveModal();
				}
			});
		});
	}
</script>
