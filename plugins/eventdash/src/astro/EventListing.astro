---
/**
 * EventListing.astro
 * Portable Text block component for displaying upcoming events.
 *
 * Props:
 *   - limit: Number of events to display (default 5)
 *   - showWaitlist: Show "Full - Join Waitlist" when at capacity (default true)
 *
 * Accessibility:
 *   - ARIA labels on form inputs for screen readers
 *   - role="status" on message regions for live announcements
 *   - Focus-visible styles for keyboard navigation
 *   - Semantic article elements per event
 *
 * Mobile:
 *   - Responsive header layout (stacks on small screens)
 *   - Touch-friendly input/button sizing
 */

interface EventRecord {
	id: string;
	title: string;
	description?: string;
	date: string;
	endDate?: string; // ISO date for multi-day events
	time: string;
	location: string;
	capacity: number;
	registered: number;
}

interface Props {
	limit?: number;
	showWaitlist?: boolean;
}

const { limit = 5, showWaitlist = true } = Astro.props;

// Fetch upcoming events from the API with error handling (P0 fix)
const apiBase = Astro.url.origin;
let events: EventRecord[] = [];

try {
	const response = await fetch(`${apiBase}/_emdash/api/plugins/eventdash/events?limit=${limit}&upcomingOnly=true`);

	if (!response.ok) {
		console.error(`Failed to fetch events: ${response.statusText}`);
	} else {
		const data = await response.json();
		events = data.events || [];
	}
} catch (error) {
	console.error('Error fetching events:', error);
}

/**
 * Format date and time for display.
 * For multi-day events, shows "Apr 5-7" style date range.
 */
function formatDateTime(date: string, time: string, endDate?: string): string {
	try {
		const [hours, minutes] = time.split(':');
		const startObj = new Date(`${date}T${hours}:${minutes}:00Z`);

		if (endDate && endDate !== date) {
			const endObj = new Date(`${endDate}T00:00:00Z`);
			const startMonth = new Intl.DateTimeFormat('en-US', { month: 'short' }).format(startObj);
			const endMonth = new Intl.DateTimeFormat('en-US', { month: 'short' }).format(endObj);
			const startDay = startObj.getUTCDate();
			const endDay = endObj.getUTCDate();

			if (startMonth === endMonth) {
				return `${startMonth} ${startDay}-${endDay}`;
			}
			return `${startMonth} ${startDay} - ${endMonth} ${endDay}`;
		}

		return new Intl.DateTimeFormat('en-US', {
			weekday: 'short',
			month: 'short',
			day: 'numeric',
			hour: 'numeric',
			minute: '2-digit',
		}).format(startObj);
	} catch {
		return `${date} at ${time}`;
	}
}

/**
 * Check if event is at capacity (P0 fix: proper type guard)
 */
function isEventFull(event: EventRecord): boolean {
	return event.registered >= event.capacity;
}
---

<div class="event-listing" role="region" aria-label="Event listings">
	{events.length === 0 ? (
		<div class="event-listing__empty">
			<p>No upcoming events scheduled.</p>
		</div>
	) : (
		<div class="event-listing__events">
			{events.map((event: EventRecord) => (
				<article class="event-listing__item" key={event.id} aria-labelledby={`event-title-${event.id}`}>
					<div class="event-listing__header">
						<h3 class="event-listing__title" id={`event-title-${event.id}`}>{event.title}</h3>
						<span
							class={`event-listing__capacity ${isEventFull(event) ? 'event-listing__capacity--full' : ''}`}
							aria-label={isEventFull(event)
								? `Event full: ${event.registered} of ${event.capacity} spots taken`
								: `${event.registered} of ${event.capacity} spots taken`}
						>
							{event.registered}/{event.capacity}
						</span>
					</div>

					{event.description && (
						<p class="event-listing__description">{event.description}</p>
					)}

					<div class="event-listing__details">
						<div class="event-listing__detail">
							<span class="event-listing__label">When:</span>
							<span class="event-listing__value">{formatDateTime(event.date, event.time, event.endDate)}</span>
						</div>
						<div class="event-listing__detail">
							<span class="event-listing__label">Where:</span>
							<span class="event-listing__value">{event.location}</span>
						</div>
					</div>

					<form class="event-listing__form" data-event-id={event.id} aria-label={`Register for ${event.title}`}>
						<label class="event-listing__sr-only" for={`name-${event.id}`}>Your name</label>
						<input
							type="text"
							name="name"
							id={`name-${event.id}`}
							placeholder="Your name"
							required
							class="event-listing__input"
							aria-required="true"
							autocomplete="name"
						/>
						<label class="event-listing__sr-only" for={`email-${event.id}`}>Email address</label>
						<input
							type="email"
							name="email"
							id={`email-${event.id}`}
							placeholder="your@email.com"
							required
							class="event-listing__input"
							aria-required="true"
							autocomplete="email"
						/>

						{isEventFull(event) && showWaitlist ? (
							<button
								type="submit"
								class="event-listing__button event-listing__button--waitlist"
								data-action="waitlist"
								aria-label={`Join waitlist for ${event.title}`}
							>
								Full — Join Waitlist
							</button>
						) : (
							<button
								type="submit"
								class="event-listing__button"
								aria-label={`Register for ${event.title}`}
							>
								Register
							</button>
						)}
					</form>

					<div
						class="event-listing__message"
						data-event-id={event.id}
						role="status"
						aria-live="polite"
					></div>
				</article>
			))}
		</div>
	)}
</div>

<script>
	/**
	 * Handle event registration form submission
	 */
	document.addEventListener('submit', async (event: Event) => {
		const form = event.target as HTMLFormElement;

		// Only handle event listing forms
		if (!form.classList.contains('event-listing__form')) return;
		if (!form.dataset.eventId) return;

		event.preventDefault();

		const eventId = form.dataset.eventId;
		const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		const name = (form.querySelector('input[name="name"]') as HTMLInputElement)?.value?.trim();
		const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value?.trim();

		if (!name || !email) {
			showMessage(eventId, 'Please fill in all fields', 'error');
			return;
		}

		// Disable submit button to prevent double clicks
		if (submitBtn) {
			submitBtn.disabled = true;
			submitBtn.textContent = 'Registering...';
		}

		try {
			const response = await fetch(
				`/_emdash/api/plugins/eventdash/register?id=${encodeURIComponent(eventId)}`,
				{
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name, email }),
				}
			);

			const result = await response.json();

			if (response.ok && result.success) {
				showMessage(eventId, result.message, 'success');
				form.reset();
			} else {
				showMessage(eventId, result.error || 'Registration failed', 'error');
			}
		} catch (error) {
			showMessage(eventId, 'An error occurred. Please try again.', 'error');
			console.error('Registration error:', error);
		} finally {
			// Re-enable submit button
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = submitBtn.dataset.action === 'waitlist'
					? 'Full \u2014 Join Waitlist'
					: 'Register';
			}
		}
	});

	/**
	 * Display message to user with focus management for accessibility
	 */
	function showMessage(eventId: string, message: string, type: 'success' | 'error') {
		const messageEl = document.querySelector(
			`[data-event-id="${eventId}"].event-listing__message`
		) as HTMLElement | null;

		if (!messageEl) return;

		messageEl.textContent = message;
		messageEl.className = `event-listing__message event-listing__message--${type}`;
		messageEl.style.display = 'block';

		// Focus the message for screen reader announcement
		messageEl.setAttribute('tabindex', '-1');
		messageEl.focus();

		// Auto-hide success messages after 4 seconds
		if (type === 'success') {
			setTimeout(() => {
				messageEl.style.display = 'none';
				messageEl.removeAttribute('tabindex');
			}, 4000);
		}
	}
</script>

<style>
	.event-listing {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.event-listing__empty {
		text-align: center;
		padding: 2rem;
		color: #666;
		font-style: italic;
	}

	.event-listing__events {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.event-listing__item {
		border: 1px solid #e0e0e0;
		border-radius: 0.5rem;
		padding: 1.5rem;
		background-color: #fafafa;
	}

	.event-listing__header {
		display: flex;
		justify-content: space-between;
		align-items: start;
		margin-bottom: 0.75rem;
		gap: 0.75rem;
	}

	.event-listing__title {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 600;
		color: #1a1a1a;
		flex: 1;
	}

	.event-listing__capacity {
		font-size: 0.875rem;
		padding: 0.25rem 0.5rem;
		background-color: #e8f5e9;
		border-radius: 0.25rem;
		color: #2e7d32;
		white-space: nowrap;
	}

	.event-listing__capacity--full {
		background-color: #ffebee;
		color: #c62828;
	}

	.event-listing__description {
		margin: 0.5rem 0 0.75rem 0;
		color: #555;
		font-size: 0.95rem;
	}

	.event-listing__details {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 1rem;
		font-size: 0.95rem;
	}

	.event-listing__detail {
		display: flex;
		gap: 0.5rem;
	}

	.event-listing__label {
		font-weight: 500;
		color: #666;
		min-width: 5rem;
	}

	.event-listing__value {
		color: #1a1a1a;
	}

	/* Screen-reader only labels */
	.event-listing__sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.event-listing__form {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.event-listing__input {
		padding: 0.75rem;
		border: 1px solid #d0d0d0;
		border-radius: 0.25rem;
		font-size: 0.95rem;
		font-family: inherit;
	}

	.event-listing__input:focus {
		outline: 2px solid #0066cc;
		outline-offset: 2px;
		border-color: #0066cc;
		box-shadow: 0 0 0 2px rgba(0, 102, 204, 0.2);
	}

	.event-listing__button {
		padding: 0.75rem 1rem;
		border: none;
		border-radius: 0.25rem;
		font-size: 0.95rem;
		font-weight: 500;
		cursor: pointer;
		transition: background-color 0.2s;
		background-color: #0066cc;
		color: white;
	}

	.event-listing__button:hover {
		background-color: #0052a3;
	}

	.event-listing__button:focus-visible {
		outline: 2px solid #0066cc;
		outline-offset: 2px;
		box-shadow: 0 0 0 4px rgba(0, 102, 204, 0.2);
	}

	.event-listing__button:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.event-listing__button--waitlist {
		background-color: #ff9800;
	}

	.event-listing__button--waitlist:hover {
		background-color: #e68900;
	}

	.event-listing__button--waitlist:focus-visible {
		outline-color: #ff9800;
		box-shadow: 0 0 0 4px rgba(255, 152, 0, 0.2);
	}

	.event-listing__message {
		display: none;
		padding: 0.75rem;
		border-radius: 0.25rem;
		font-size: 0.9rem;
	}

	.event-listing__message:focus {
		outline: none;
	}

	.event-listing__message--success {
		background-color: #e8f5e9;
		color: #2e7d32;
		border-left: 4px solid #2e7d32;
	}

	.event-listing__message--error {
		background-color: #ffebee;
		color: #c62828;
		border-left: 4px solid #c62828;
	}

	/* Mobile responsive */
	@media (max-width: 768px) {
		.event-listing__item {
			padding: 1rem;
		}

		.event-listing__header {
			flex-direction: column;
			gap: 0.5rem;
		}

		.event-listing__title {
			font-size: 1.1rem;
		}

		.event-listing__capacity {
			align-self: flex-start;
		}

		.event-listing__input {
			padding: 0.875rem;
			font-size: 1rem;
		}

		.event-listing__button {
			padding: 0.875rem 1rem;
			font-size: 1rem;
		}
	}

	@media (max-width: 480px) {
		.event-listing__item {
			padding: 0.75rem;
			border-radius: 0.25rem;
		}

		.event-listing__details {
			font-size: 0.875rem;
		}

		.event-listing__label {
			min-width: 4rem;
		}
	}
</style>
