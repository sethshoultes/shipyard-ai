---
/**
 * AttendeePortal.astro — Task 8 (Phase 3 Wave 2)
 *
 * Attendee portal: my registrations and events.
 * Shows upcoming registered events with details, past events with badges.
 *
 * Features:
 * - "My Events" — upcoming registrations with event details
 * - Show past events with "attended" badge
 * - Show check-in code for upcoming events
 * - Show ticket type + payment status
 * - Clean, minimal design
 * - Fetch from /eventdash/portal API endpoint
 *
 * Props from Portable Text block:
 *   - showCheckInCodes?: boolean (default true)
 *   - showPastEvents?: boolean (default true)
 *   - title?: string (custom title, default "My Events")
 */

interface RegistrationRecord {
	eventId: string;
	eventTitle: string;
	eventDate: string; // ISO date (start)
	eventEndDate?: string; // ISO date (end, for multi-day events)
	eventTime: string; // HH:MM format
	eventLocation: string;
	ticketType?: string;
	checkInCode?: string;
	checkedIn?: boolean;
	checkedInAt?: string; // ISO timestamp
	paymentStatus?: "pending" | "paid" | "refunded";
	amountPaid?: number; // In cents
}

interface PortalData {
	attendee?: {
		name?: string;
		email?: string;
	};
	upcomingRegistrations: RegistrationRecord[];
	pastRegistrations: RegistrationRecord[];
	lastSync?: string; // ISO date
}

interface Props {
	showCheckInCodes?: boolean;
	showPastEvents?: boolean;
	title?: string;
}

const {
	showCheckInCodes = true,
	showPastEvents = true,
	title = "My Events",
} = Astro.props;

// Get attendee email from cookie
const attendeeEmail = Astro.cookies.get("eventdash-email")?.value?.toLowerCase() || "";

let portalData: PortalData = {
	upcomingRegistrations: [],
	pastRegistrations: [],
};

let error: string | null = null;

// Fetch portal data from API
if (attendeeEmail) {
	try {
		const response = await fetch(
			new URL(
				`/_emdash/api/plugins/eventdash/portal?email=${encodeURIComponent(attendeeEmail)}`,
				Astro.url.origin
			),
			{ credentials: "include" }
		);

		if (response.ok) {
			portalData = (await response.json()) as PortalData;
		} else {
			error = "Failed to load your events";
		}
	} catch (err) {
		console.error("Portal data fetch error:", err);
		error = "Error loading your event registrations";
	}
}

/**
 * Format date and time for display.
 * For multi-day events, shows "Apr 5-7, 2026" style date range.
 */
function formatDateTime(dateStr: string, timeStr: string, endDateStr?: string): string {
	try {
		const [hours, minutes] = timeStr.split(":");
		const startObj = new Date(`${dateStr}T${hours}:${minutes}:00Z`);

		if (endDateStr && endDateStr !== dateStr) {
			const endObj = new Date(`${endDateStr}T00:00:00Z`);
			const startMonth = new Intl.DateTimeFormat("en-US", { month: "short" }).format(startObj);
			const endMonth = new Intl.DateTimeFormat("en-US", { month: "short" }).format(endObj);
			const startDay = startObj.getUTCDate();
			const endDay = endObj.getUTCDate();
			const year = startObj.getUTCFullYear();

			if (startMonth === endMonth) {
				return `${startMonth} ${startDay}-${endDay}, ${year}`;
			}
			return `${startMonth} ${startDay} - ${endMonth} ${endDay}, ${year}`;
		}

		return new Intl.DateTimeFormat("en-US", {
			weekday: "short",
			month: "short",
			day: "numeric",
			year: "numeric",
			hour: "numeric",
			minute: "2-digit",
			hour12: true,
		}).format(startObj);
	} catch {
		return `${dateStr} at ${timeStr}`;
	}
}

/**
 * Check if event is in the past
 */
function isEventPast(dateStr: string, timeStr: string): boolean {
	try {
		const [hours, minutes] = timeStr.split(":");
		const eventDate = new Date(`${dateStr}T${hours}:${minutes}:00Z`);
		return eventDate < new Date();
	} catch {
		return false;
	}
}

/**
 * Format payment status
 */
function formatPaymentStatus(status?: string): string {
	if (!status) return "Paid";
	return status === "pending"
		? "Pending"
		: status === "refunded"
			? "Refunded"
			: "Paid";
}

/**
 * Format currency
 */
function formatCurrency(cents?: number): string {
	if (!cents) return "N/A";
	return new Intl.NumberFormat("en-US", {
		style: "currency",
		currency: "USD",
	}).format(cents / 100);
}

const upcomingCount = portalData.upcomingRegistrations.length;
const pastCount = portalData.pastRegistrations.length;
const totalCount = upcomingCount + pastCount;
---

<div class="attendee-portal" role="region" aria-label="Attendee portal">
	<!-- Header -->
	<div class="attendee-portal__header">
		<h2 class="attendee-portal__title" id="portal-title">{title}</h2>
		{portalData.attendee?.name && (
			<p class="attendee-portal__welcome">
				Welcome back, <span class="attendee-portal__name">{portalData.attendee.name}</span>
			</p>
		)}
		{totalCount > 0 && (
			<p class="attendee-portal__count">
				You have {totalCount} registered event{totalCount !== 1 ? "s" : ""}
			</p>
		)}
	</div>

	<!-- Error state -->
	{error && (
		<div class="attendee-portal__error" role="alert">
			<p>{error}</p>
			<a href="#retry" class="attendee-portal__retry-btn" aria-label="Retry loading events">Retry</a>
		</div>
	)}

	<!-- Upcoming events section -->
	{upcomingCount > 0 ? (
		<div class="attendee-portal__upcoming-section">
			<h3 class="attendee-portal__section-title">
				Upcoming Events ({upcomingCount})
			</h3>
			<div class="attendee-portal__events-list">
				{portalData.upcomingRegistrations.map((reg) => (
					<article class="attendee-portal__event-card" aria-label={`Registration for ${reg.eventTitle}`}>
						<div class="attendee-portal__event-header">
							<div class="attendee-portal__event-info">
								<h4 class="attendee-portal__event-title">{reg.eventTitle}</h4>
								<p class="attendee-portal__event-datetime">
									{formatDateTime(reg.eventDate, reg.eventTime, reg.eventEndDate)}
								</p>
								<p class="attendee-portal__event-location">{reg.eventLocation}</p>
							</div>

							<div class="attendee-portal__event-meta">
								{reg.ticketType && (
									<span class="attendee-portal__ticket-type">{reg.ticketType}</span>
								)}
								{reg.paymentStatus && (
									<span class={`attendee-portal__payment-status attendee-portal__payment-status--${reg.paymentStatus}`}>
										{formatPaymentStatus(reg.paymentStatus)}
									</span>
								)}
							</div>
						</div>

						<!-- Check-in code section -->
						{showCheckInCodes && reg.checkInCode && (
							<div class={`attendee-portal__check-in ${reg.checkedIn ? "attendee-portal__check-in--checked" : ""}`}>
								{reg.checkedIn ? (
									<>
										<p class="attendee-portal__check-in-status">
											✓ Checked in {reg.checkedInAt ? `on ${new Date(reg.checkedInAt).toLocaleDateString()}` : ""}
										</p>
									</>
								) : (
									<>
										<p class="attendee-portal__check-in-label">Check-in Code:</p>
										<code class="attendee-portal__check-in-code">{reg.checkInCode}</code>
										<p class="attendee-portal__check-in-hint">Show this code at the entrance</p>
									</>
								)}
							</div>
						)}

						<!-- Additional details -->
						{reg.amountPaid && (
							<p class="attendee-portal__event-amount">
								Amount paid: {formatCurrency(reg.amountPaid)}
							</p>
						)}

						<!-- Actions -->
						<div class="attendee-portal__event-actions">
							<a
								href={`/events/${reg.eventId}`}
								class="attendee-portal__event-link"
							>
								View Details →
							</a>
							{reg.ticketType && (
								<button
									class="attendee-portal__event-ical"
									data-event-id={reg.eventId}
									data-event-date={reg.eventDate}
									data-event-end-date={reg.eventEndDate || ""}
									data-event-time={reg.eventTime}
									data-event-title={reg.eventTitle}
									data-event-location={reg.eventLocation}
									aria-label={`Add ${reg.eventTitle} to calendar`}
								>
									Add to Calendar
								</button>
							)}
						</div>
					</div>
				))}
			</div>
		</div>
	) : (
		<div class="attendee-portal__empty">
			<p>No upcoming events. <a href="/events">Browse events</a> to register.</p>
		</div>
	)}

	<!-- Past events section -->
	{showPastEvents && pastCount > 0 && (
		<div class="attendee-portal__past-section">
			<h3 class="attendee-portal__section-title">
				Past Events ({pastCount})
			</h3>
			<div class="attendee-portal__past-list">
				{portalData.pastRegistrations.map((reg) => (
					<div class="attendee-portal__past-event">
						<div class="attendee-portal__past-event-header">
							<div>
								<h4 class="attendee-portal__past-event-title">{reg.eventTitle}</h4>
								<p class="attendee-portal__past-event-date">
									{formatDateTime(reg.eventDate, reg.eventTime, reg.eventEndDate)}
								</p>
							</div>

							{reg.checkedIn && (
								<span class="attendee-portal__attended-badge">✓ Attended</span>
							)}
						</div>

						{reg.eventLocation && (
							<p class="attendee-portal__past-event-location">{reg.eventLocation}</p>
						)}
					</div>
				))}
			</div>
		</div>
	)}

	<!-- Footer with last sync info -->
	{portalData.lastSync && (
		<div class="attendee-portal__footer">
			<p class="attendee-portal__last-sync">
				Last updated: {new Date(portalData.lastSync).toLocaleString()}
			</p>
		</div>
	)}
</div>

<script>
	/**
	 * Handle "Add to Calendar" button clicks
	 * Creates ICS file and triggers download
	 */
	document.addEventListener("click", (e: Event) => {
		const target = e.target as HTMLElement;

		if (target.classList.contains("attendee-portal__event-ical")) {
			const eventId = target.dataset.eventId || "";
			const eventDate = target.dataset.eventDate || "";
			const eventEndDate = target.dataset.eventEndDate || "";
			const eventTime = target.dataset.eventTime || "";
			const eventTitle = target.dataset.eventTitle || "";
			const eventLocation = target.dataset.eventLocation || "";

			if (!eventDate || !eventTime || !eventTitle) return;

			// Parse date and time
			const [hours, minutes] = eventTime.split(":");
			const eventDateTime = new Date(`${eventDate}T${hours}:${minutes}:00Z`);

			// For multi-day events, end date is end of the last day
			let eventEndDateTime: Date | undefined;
			if (eventEndDate && eventEndDate !== eventDate) {
				eventEndDateTime = new Date(`${eventEndDate}T23:59:00Z`);
			}

			// Create iCal event
			const icsContent = createICS(eventDateTime, eventTitle, eventLocation, eventEndDateTime);

			// Create blob and download
			const blob = new Blob([icsContent], { type: "text/calendar" });
			const url = URL.createObjectURL(blob);
			const link = document.createElement("a");
			link.href = url;
			link.download = `${eventTitle.replace(/\s+/g, "-")}.ics`;
			document.body.appendChild(link);
			link.click();
			document.body.removeChild(link);
			URL.revokeObjectURL(url);
		}
	});

	/**
	 * Generate iCal (ICS) format string for an event
	 */
	function createICS(
		eventDate: Date,
		eventTitle: string,
		eventLocation: string,
		endDateTime?: Date
	): string {
		const now = new Date();

		// Format dates in iCal format (YYYYMMDDTHHMMSSZ)
		const formatICSDate = (date: Date) => {
			return (
				date.getUTCFullYear() +
				String(date.getUTCMonth() + 1).padStart(2, "0") +
				String(date.getUTCDate()).padStart(2, "0") +
				"T" +
				String(date.getUTCHours()).padStart(2, "0") +
				String(date.getUTCMinutes()).padStart(2, "0") +
				String(date.getUTCSeconds()).padStart(2, "0") +
				"Z"
			);
		};

		const startTime = formatICSDate(eventDate);
		const endTime = endDateTime
			? formatICSDate(endDateTime)
			: formatICSDate(new Date(eventDate.getTime() + 60 * 60 * 1000)); // +1 hour default
		const createdTime = formatICSDate(now);
		const uid = `event-${Date.now()}@events.local`;

		return (
			`BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Events//Events//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
BEGIN:VEVENT
UID:${uid}
DTSTAMP:${createdTime}
DTSTART:${startTime}
DTEND:${endTime}
SUMMARY:${eventTitle}
LOCATION:${eventLocation || "TBD"}
STATUS:CONFIRMED
SEQUENCE:0
END:VEVENT
END:VCALENDAR`.trim()
		);
	}
</script>

