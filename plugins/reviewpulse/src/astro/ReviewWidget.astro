---
/**
 * ReviewWidget.astro
 * Portable Text block component for displaying customer reviews with star ratings.
 *
 * Props:
 *   - count: Number of reviews to display (default 5)
 *   - layout: "list" | "grid" | "compact" (default "list")
 *   - showAuthors: Show author names (default true)
 *   - showDates: Show review dates (default true)
 *   - heading: Custom heading text (default "What Our Customers Say")
 *
 * Accessibility:
 *   - ARIA labels on star ratings ("4.3 out of 5 stars")
 *   - Semantic article elements per review
 *   - role="img" on star displays with descriptive labels
 *   - Focus-visible styles for interactive elements
 *
 * Theming:
 *   - All colors use CSS custom properties with brand fallbacks
 *   - Inherits site typography and spacing tokens
 *
 * Mobile:
 *   - Grid layout: 3 cols → 2 cols → 1 col
 *   - List and compact layouts stack naturally
 */

interface ReviewRecord {
	id: string;
	author: string;
	rating: number;
	date: string;
	text: string;
}

interface WidgetData {
	averageRating: number;
	totalReviews: number;
	reviews: ReviewRecord[];
}

interface Props {
	count?: number;
	layout?: "list" | "grid" | "compact";
	showAuthors?: boolean;
	showDates?: boolean;
	heading?: string;
}

const {
	count = 5,
	layout = "list",
	showAuthors = true,
	showDates = true,
	heading = "What Our Customers Say",
} = Astro.props;

// Fetch widget data from the public API endpoint
const apiBase = Astro.url.origin;
let widgetData: WidgetData | null = null;

try {
	const response = await fetch(
		`${apiBase}/_emdash/api/plugins/reviewpulse/widget-data?count=${count}`
	);

	if (!response.ok) {
		console.error(`Failed to fetch reviews: ${response.statusText}`);
	} else {
		widgetData = (await response.json()) as WidgetData;
	}
} catch (error) {
	console.error("Error fetching reviews:", error);
}

const reviews = widgetData?.reviews ?? [];
const averageRating = widgetData?.averageRating ?? 0;
const totalReviews = widgetData?.totalReviews ?? 0;

/**
 * Format a date string for display.
 */
function formatDate(dateStr: string): string {
	try {
		const date = new Date(dateStr);
		return new Intl.DateTimeFormat("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		}).format(date);
	} catch {
		return dateStr;
	}
}

/**
 * Truncate text to a maximum character length, breaking at word boundaries.
 */
function truncateText(text: string, maxLength: number = 180): { truncated: string; isTruncated: boolean } {
	if (text.length <= maxLength) return { truncated: text, isTruncated: false };
	const cut = text.slice(0, maxLength);
	const lastSpace = cut.lastIndexOf(" ");
	return {
		truncated: (lastSpace > 0 ? cut.slice(0, lastSpace) : cut) + "\u2026",
		isTruncated: true,
	};
}

/**
 * Generate star ARIA label text.
 */
function starLabel(rating: number): string {
	return `${rating.toFixed(1)} out of 5 stars`;
}

// Layout class for the reviews container
const layoutClass = `review-widget__reviews--${layout}`;
---

<div class="review-widget" data-layout={layout} role="region" aria-label="Customer reviews">
	{widgetData === null ? (
		<div class="review-widget__empty">
			<p>Reviews are currently unavailable.</p>
		</div>
	) : (
		<>
			{/* Summary header */}
			<div class="review-widget__header">
				<h2 class="review-widget__heading">{heading}</h2>
				<div class="review-widget__summary">
					<div
						class="review-widget__stars"
						role="img"
						aria-label={starLabel(averageRating)}
					>
						{[1, 2, 3, 4, 5].map((i) => {
							const fill = Math.min(1, Math.max(0, averageRating - (i - 1)));
							const clipId = `star-summary-${i}`;
							return (
								<svg
									class="review-widget__star"
									viewBox="0 0 20 20"
									width="24"
									height="24"
									aria-hidden="true"
								>
									<defs>
										<clipPath id={clipId}>
											<rect x="0" y="0" width={fill * 20} height="20" />
										</clipPath>
									</defs>
									<path
										class="review-widget__star-bg"
										d="M10 1l2.39 5.64L18 7.24l-4 4.13L15 18l-5-3.07L5 18l1-6.63-4-4.13 5.61-.6z"
									/>
									<path
										class="review-widget__star-fill"
										d="M10 1l2.39 5.64L18 7.24l-4 4.13L15 18l-5-3.07L5 18l1-6.63-4-4.13 5.61-.6z"
										clip-path={`url(#${clipId})`}
									/>
								</svg>
							);
						})}
					</div>
					<span class="review-widget__rating-text">
						{averageRating.toFixed(1)} out of 5
					</span>
					<span class="review-widget__count">
						({totalReviews} {totalReviews === 1 ? "review" : "reviews"})
					</span>
				</div>
			</div>

			{/* Reviews list */}
			{reviews.length === 0 ? (
				<div class="review-widget__empty">
					<p>No reviews yet. Be the first to leave a review!</p>
				</div>
			) : (
				<div class={`review-widget__reviews ${layoutClass}`}>
					{reviews.map((review: ReviewRecord) => {
						const { truncated, isTruncated } = truncateText(
							review.text,
							layout === "compact" ? 100 : 180
						);
						return (
							<article
								class="review-widget__review"
								key={review.id}
								aria-labelledby={`review-author-${review.id}`}
							>
								<div
									class="review-widget__review-stars"
									role="img"
									aria-label={starLabel(review.rating)}
								>
									{[1, 2, 3, 4, 5].map((i) => {
										const fill = Math.min(1, Math.max(0, review.rating - (i - 1)));
										const clipId = `star-${review.id}-${i}`;
										return (
											<svg
												class="review-widget__star review-widget__star--sm"
												viewBox="0 0 20 20"
												width="18"
												height="18"
												aria-hidden="true"
											>
												<defs>
													<clipPath id={clipId}>
														<rect x="0" y="0" width={fill * 20} height="20" />
													</clipPath>
												</defs>
												<path
													class="review-widget__star-bg"
													d="M10 1l2.39 5.64L18 7.24l-4 4.13L15 18l-5-3.07L5 18l1-6.63-4-4.13 5.61-.6z"
												/>
												<path
													class="review-widget__star-fill"
													d="M10 1l2.39 5.64L18 7.24l-4 4.13L15 18l-5-3.07L5 18l1-6.63-4-4.13 5.61-.6z"
													clip-path={`url(#${clipId})`}
												/>
											</svg>
										);
									})}
								</div>

								<div class="review-widget__review-body">
									<p class="review-widget__review-text" data-review-id={review.id}>
										<span class="review-widget__text-truncated">{truncated}</span>
										{isTruncated && (
											<>
												<span class="review-widget__text-full" hidden>{review.text}</span>
												<button
													class="review-widget__read-more"
													data-review-id={review.id}
													aria-expanded="false"
													type="button"
												>
													read more
												</button>
											</>
										)}
									</p>
								</div>

								<div class="review-widget__review-meta">
									{showAuthors && (
										<span
											class="review-widget__author"
											id={`review-author-${review.id}`}
										>
											{review.author}
										</span>
									)}
									{showAuthors && showDates && (
										<span class="review-widget__meta-sep" aria-hidden="true">&middot;</span>
									)}
									{showDates && (
										<time
											class="review-widget__date"
											datetime={review.date}
										>
											{formatDate(review.date)}
										</time>
									)}
								</div>
							</article>
						);
					})}
				</div>
			)}
		</>
	)}
</div>

<script>
	/**
	 * Handle "read more" / "read less" toggle for truncated review text.
	 */
	document.addEventListener("click", (event: Event) => {
		const target = event.target as HTMLElement;
		if (!target.classList.contains("review-widget__read-more")) return;

		const reviewId = target.dataset.reviewId;
		if (!reviewId) return;

		const container = target.closest(".review-widget__review-text");
		if (!container) return;

		const truncatedEl = container.querySelector(".review-widget__text-truncated") as HTMLElement | null;
		const fullEl = container.querySelector(".review-widget__text-full") as HTMLElement | null;

		if (!truncatedEl || !fullEl) return;

		const isExpanded = target.getAttribute("aria-expanded") === "true";

		if (isExpanded) {
			truncatedEl.hidden = false;
			fullEl.hidden = true;
			target.setAttribute("aria-expanded", "false");
			target.textContent = "read more";
		} else {
			truncatedEl.hidden = true;
			fullEl.hidden = false;
			target.setAttribute("aria-expanded", "true");
			target.textContent = "read less";
		}
	});
</script>

<style>
	/* -------------------------------------------------------
	   ReviewWidget — themed via CSS custom properties
	   Fallbacks use the standard brand palette:
	     Terracotta #C4704B, Sage #7A8B6F, Gold #D4A853,
	     Charcoal #2C2C2C, Warm White #FAF8F5
	   ------------------------------------------------------- */

	.review-widget {
		font-family: var(--font-body, "Source Sans 3", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
		color: var(--color-text, #2C2C2C);
		line-height: 1.6;
		/* Reserve space to prevent layout shift during load */
		min-height: 12rem;
	}

	/* Header + summary
	   ------------------------------------------------------- */

	.review-widget__header {
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border, #e5e5e5);
		padding-bottom: 1.25rem;
	}

	.review-widget__heading {
		font-family: var(--font-heading, Lora, serif);
		font-size: 1.75rem;
		font-weight: 600;
		margin: 0 0 0.75rem 0;
		color: var(--color-text, #2C2C2C);
	}

	.review-widget__summary {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.review-widget__stars {
		display: flex;
		gap: 0.125rem;
	}

	.review-widget__star-bg {
		fill: var(--color-star-bg, #e0dbd5);
	}

	.review-widget__star-fill {
		fill: var(--color-accent, #D4A853);
	}

	.review-widget__rating-text {
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--color-text, #2C2C2C);
	}

	.review-widget__count {
		font-size: 0.95rem;
		color: var(--color-text-secondary, #666);
	}

	/* Empty state
	   ------------------------------------------------------- */

	.review-widget__empty {
		text-align: center;
		padding: 2rem;
		color: var(--color-text-secondary, #666);
		font-style: italic;
	}

	/* Reviews container — layout variants
	   ------------------------------------------------------- */

	.review-widget__reviews {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	/* Grid layout */
	.review-widget__reviews--grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	/* Compact layout — tighter spacing, smaller text */
	.review-widget__reviews--compact {
		gap: 0.75rem;
	}

	/* Individual review card
	   ------------------------------------------------------- */

	.review-widget__review {
		background: var(--color-surface, #FAF8F5);
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: 0.5rem;
		padding: 1.25rem;
	}

	.review-widget__reviews--compact .review-widget__review {
		padding: 0.875rem;
	}

	.review-widget__review-stars {
		display: flex;
		gap: 0.0625rem;
		margin-bottom: 0.5rem;
	}

	.review-widget__star--sm {
		/* size set via width/height attributes */
	}

	/* Review text + read more
	   ------------------------------------------------------- */

	.review-widget__review-body {
		margin-bottom: 0.75rem;
	}

	.review-widget__review-text {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-text, #2C2C2C);
		line-height: 1.55;
	}

	.review-widget__reviews--compact .review-widget__review-text {
		font-size: 0.875rem;
	}

	.review-widget__read-more {
		background: none;
		border: none;
		color: var(--color-primary, #C4704B);
		cursor: pointer;
		font-size: 0.875rem;
		font-weight: 500;
		padding: 0;
		margin-left: 0.25rem;
		font-family: inherit;
		text-decoration: underline;
		text-decoration-color: transparent;
		transition: text-decoration-color 0.2s;
	}

	.review-widget__read-more:hover {
		text-decoration-color: var(--color-primary, #C4704B);
	}

	.review-widget__read-more:focus-visible {
		outline: 2px solid var(--color-primary, #C4704B);
		outline-offset: 2px;
		border-radius: 2px;
	}

	/* Review meta (author + date)
	   ------------------------------------------------------- */

	.review-widget__review-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-text-secondary, #666);
	}

	.review-widget__author {
		font-weight: 600;
		color: var(--color-text, #2C2C2C);
	}

	.review-widget__date {
		color: var(--color-text-secondary, #666);
	}

	/* Responsive — grid adjustments
	   ------------------------------------------------------- */

	@media (max-width: 960px) {
		.review-widget__reviews--grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.review-widget__reviews--grid {
			grid-template-columns: 1fr;
		}

		.review-widget__heading {
			font-size: 1.35rem;
		}

		.review-widget__review {
			padding: 1rem;
		}

		.review-widget__reviews--compact .review-widget__review {
			padding: 0.75rem;
		}
	}

	@media (max-width: 480px) {
		.review-widget__review {
			border-radius: 0.25rem;
			padding: 0.75rem;
		}

		.review-widget__summary {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}
	}
</style>
