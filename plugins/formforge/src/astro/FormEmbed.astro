---
/**
 * FormEmbed.astro — FormForge Wave 1
 *
 * Universal form embed component that renders dynamic form definitions
 * fetched by form ID from the FormForge API.
 *
 * Features:
 * - 10 field types: text, email, textarea, number, phone, date, dropdown, radio, checkbox, hidden
 * - Client-side validation: required, email format, phone format, number range
 * - Conditional logic: showWhen rules — show/hide fields based on other field values
 * - Honeypot: hidden _hp field rejects bots server-side
 * - Multi-step wizard: progress indicator, back/next, per-step validation
 * - Submit via fetch: POST JSON to /_emdash/api/plugins/formforge/submit
 * - Success/error states with confirmation or field-level errors
 * - Mobile responsive: single column, full-width controls
 * - Theme inheritance: CSS custom properties with brand palette fallbacks
 * - Accessible: labels, aria-required, aria-invalid, aria-describedby, aria-live, focus management
 *
 * Props:
 *   - formId: string (required) — ID of the form definition to render
 *   - heading?: string — optional heading above the form
 *   - submitLabel?: string — custom submit button text (default: "Submit")
 *   - successMessage?: string — custom success message
 *   - compact?: boolean — compact mode for embedded contexts (smaller spacing)
 */

interface ConditionalRule {
	fieldId: string;
	operator: "equals" | "not_equals" | "contains" | "not_empty";
	value?: string;
}

interface FormFieldDefinition {
	id: string;
	type: "text" | "email" | "textarea" | "number" | "phone" | "date" | "dropdown" | "radio" | "checkbox" | "hidden";
	label: string;
	required: boolean;
	options?: string[];
	placeholder?: string;
	min?: number;
	max?: number;
	rows?: number;
	defaultValue?: string;
	showWhen?: ConditionalRule;
}

interface FormStep {
	label: string;
	fieldIds: string[];
}

interface FormDefinition {
	id: string;
	name: string;
	description?: string;
	fields: FormFieldDefinition[];
	steps?: FormStep[];
	createdAt: string;
	updatedAt: string;
}

interface Props {
	formId: string;
	heading?: string;
	submitLabel?: string;
	successMessage?: string;
	compact?: boolean;
}

const {
	formId,
	heading,
	submitLabel = "Submit",
	successMessage = "Thank you! Your submission has been received.",
	compact = false,
} = Astro.props;

let form: FormDefinition | null = null;
let error: string | null = null;

// Fetch form definition from API
if (formId) {
	try {
		const response = await fetch(
			new URL(
				`/_emdash/api/plugins/formforge/forms/${encodeURIComponent(formId)}`,
				Astro.url.origin
			),
			{ credentials: "include" }
		);

		if (response.ok) {
			const data = (await response.json()) as { form: FormDefinition };
			form = data.form;
		} else if (response.status === 404) {
			error = "This form is no longer available.";
		} else {
			error = "Unable to load the form. Please try again later.";
		}
	} catch (err) {
		console.error("FormForge form fetch error:", err);
		error = "Error loading the form. Please try again later.";
	}
} else {
	error = "No form ID provided.";
}

const formTitle = heading || form?.name || "Form";
const formDescription = form?.description;
// Unique identifier for this form instance (supports multiple forms on one page)
const instanceId = `ff-form-${formId}`;

// Multi-step wizard support
const hasSteps = !!(form?.steps && form.steps.length > 1);
const steps = form?.steps || [];
const totalSteps = steps.length;

// Build a lookup: fieldId -> stepIndex (for wizard mode)
const fieldStepMap: Record<string, number> = {};
if (hasSteps) {
	steps.forEach((step, idx) => {
		step.fieldIds.forEach((fid) => {
			fieldStepMap[fid] = idx;
		});
	});
}

// Build conditional logic metadata for client-side JS
const conditionalRules: Record<string, ConditionalRule> = {};
if (form) {
	for (const field of form.fields) {
		if (field.showWhen) {
			conditionalRules[field.id] = field.showWhen;
		}
	}
}
---

<div
	class={`ff-form ${compact ? "ff-form--compact" : ""}`}
	data-form-id={formId}
	id={instanceId}
>
	{error ? (
		<div class="ff-form__error-banner" role="alert" aria-live="polite">
			<p>{error}</p>
		</div>
	) : form ? (
		<>
			<div class="ff-form__header">
				<h2 class="ff-form__title">{formTitle}</h2>
				{formDescription && !compact && (
					<p class="ff-form__description">{formDescription}</p>
				)}
			</div>

			<form
				class="ff-form__form"
				data-form-id={formId}
				data-submit-url={`/_emdash/api/plugins/formforge/submit`}
				data-has-steps={hasSteps ? "true" : "false"}
				data-total-steps={totalSteps.toString()}
				data-steps-json={hasSteps ? JSON.stringify(steps) : ""}
				data-conditional-rules={Object.keys(conditionalRules).length > 0 ? JSON.stringify(conditionalRules) : ""}
				novalidate
				aria-label={formTitle}
			>
				{/* Honeypot field — hidden from humans, traps bots */}
				<div class="ff-form__hp" aria-hidden="true">
					<label for={`${instanceId}-_hp`}>Leave this empty</label>
					<input
						type="text"
						id={`${instanceId}-_hp`}
						name="_hp"
						tabindex={-1}
						autocomplete="off"
					/>
				</div>

				{/* Progress indicator for multi-step forms */}
				{hasSteps && (
					<div class="ff-form__progress" role="navigation" aria-label="Form progress">
						<p class="ff-form__progress-text">
							Step <span data-current-step>1</span> of {totalSteps}
						</p>
						<div class="ff-form__progress-bar">
							<div
								class="ff-form__progress-fill"
								style={`width: ${(1 / totalSteps) * 100}%`}
								role="progressbar"
								aria-valuenow={1}
								aria-valuemin={1}
								aria-valuemax={totalSteps}
							></div>
						</div>
						<p class="ff-form__step-label" aria-live="polite">
							{steps[0].label}
						</p>
					</div>
				)}

				<div class="ff-form__fields">
					{form.fields.map((field) => (
						<div
							class={`ff-form__field ff-form__field--${field.type}`}
							data-field-id={field.id}
							data-field-type={field.type}
							data-field-required={field.required ? "true" : "false"}
							data-step-index={hasSteps && fieldStepMap[field.id] !== undefined ? fieldStepMap[field.id].toString() : undefined}
							data-show-when={field.showWhen ? JSON.stringify(field.showWhen) : undefined}
						>
							{/* Hidden fields: no label, just a hidden input */}
							{field.type === "hidden" && (
								<input
									type="hidden"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									value={field.defaultValue || ""}
								/>
							)}

							{/* Checkbox: label wraps the input */}
							{field.type === "checkbox" && (
								<div class="ff-form__checkbox-wrapper">
									<input
										type="checkbox"
										id={`${instanceId}-${field.id}`}
										name={field.id}
										class="ff-form__checkbox"
										aria-required={field.required ? "true" : undefined}
										aria-describedby={`${instanceId}-${field.id}-error`}
									/>
									<label
										for={`${instanceId}-${field.id}`}
										class="ff-form__checkbox-label"
									>
										{field.label}
										{field.required && (
											<span class="ff-form__required" aria-hidden="true">*</span>
										)}
									</label>
								</div>
							)}

							{/* Radio: fieldset with legend */}
							{field.type === "radio" && field.options && (
								<fieldset class="ff-form__radio-fieldset">
									<legend class="ff-form__label">
										{field.label}
										{field.required && (
											<span class="ff-form__required" aria-hidden="true">*</span>
										)}
									</legend>
									<div class="ff-form__radio-group" role="radiogroup" aria-required={field.required ? "true" : undefined}>
										{field.options.map((opt, idx) => (
											<div class="ff-form__radio-option">
												<input
													type="radio"
													id={`${instanceId}-${field.id}-${idx}`}
													name={field.id}
													value={opt}
													class="ff-form__radio"
													aria-describedby={`${instanceId}-${field.id}-error`}
												/>
												<label
													for={`${instanceId}-${field.id}-${idx}`}
													class="ff-form__radio-label"
												>
													{opt}
												</label>
											</div>
										))}
									</div>
								</fieldset>
							)}

							{/* All other field types: standard label above input */}
							{field.type !== "checkbox" && field.type !== "radio" && field.type !== "hidden" && (
								<label
									for={`${instanceId}-${field.id}`}
									class="ff-form__label"
								>
									{field.label}
									{field.required && (
										<span class="ff-form__required" aria-hidden="true">*</span>
									)}
								</label>
							)}

							{field.type === "text" && (
								<input
									type="text"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__input"
									placeholder={field.placeholder || ""}
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "email" && (
								<input
									type="email"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__input"
									placeholder={field.placeholder || "you@example.com"}
									autocomplete="email"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "phone" && (
								<input
									type="tel"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__input"
									placeholder={field.placeholder || "(555) 123-4567"}
									autocomplete="tel"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "number" && (
								<input
									type="number"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__input"
									placeholder={field.placeholder || ""}
									min={field.min !== undefined ? field.min.toString() : undefined}
									max={field.max !== undefined ? field.max.toString() : undefined}
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "date" && (
								<input
									type="date"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__input"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "textarea" && (
								<textarea
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__textarea"
									placeholder={field.placeholder || ""}
									rows={field.rows || 4}
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								></textarea>
							)}

							{field.type === "dropdown" && field.options && (
								<select
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="ff-form__select"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								>
									<option value="">{field.placeholder || `Select ${field.label.toLowerCase()}...`}</option>
									{field.options.map((opt) => (
										<option value={opt}>{opt}</option>
									))}
								</select>
							)}

							{/* Field error — not rendered for hidden fields */}
							{field.type !== "hidden" && (
								<p
									class="ff-form__field-error"
									id={`${instanceId}-${field.id}-error`}
									role="alert"
									aria-live="polite"
								></p>
							)}
						</div>
					))}
				</div>

				<div class="ff-form__actions">
					{hasSteps && (
						<button
							type="button"
							class="ff-form__back"
							style="display: none;"
							aria-label="Go to previous step"
						>
							Back
						</button>
					)}
					{hasSteps && (
						<button
							type="button"
							class="ff-form__next"
							aria-label="Go to next step"
						>
							Next
						</button>
					)}
					<button
						type="submit"
						class="ff-form__submit"
						style={hasSteps ? "display: none;" : undefined}
					>
						{submitLabel}
					</button>
				</div>

				<div
					class="ff-form__status"
					role="status"
					aria-live="polite"
					style="display: none;"
				></div>
			</form>

			<div
				class="ff-form__success"
				role="status"
				aria-live="polite"
				style="display: none;"
			>
				<div class="ff-form__success-icon" aria-hidden="true">&#10003;</div>
				<p class="ff-form__success-message">{successMessage}</p>
			</div>
		</>
	) : (
		<div class="ff-form__loading" role="status" aria-live="polite">
			<p>Loading form...</p>
		</div>
	)}
</div>

<script define:vars={{ instanceId, formId }}>
	document.addEventListener("DOMContentLoaded", () => {
		const container = document.getElementById(instanceId);
		if (!container) return;

		const formEl = container.querySelector("form[data-form-id]");
		if (!formEl) return;

		const submitUrl = formEl.getAttribute("data-submit-url");
		const successEl = container.querySelector(".ff-form__success");
		const statusEl = container.querySelector(".ff-form__status");
		const submitBtn = formEl.querySelector(".ff-form__submit");

		// Multi-step wizard state
		const hasSteps = formEl.getAttribute("data-has-steps") === "true";
		const totalSteps = parseInt(formEl.getAttribute("data-total-steps") || "0", 10);
		const stepsJson = formEl.getAttribute("data-steps-json");
		const stepsConfig = stepsJson ? JSON.parse(stepsJson) : [];
		let currentStep = 0;

		const backBtn = formEl.querySelector(".ff-form__back");
		const nextBtn = formEl.querySelector(".ff-form__next");
		const progressText = formEl.querySelector("[data-current-step]");
		const progressFill = formEl.querySelector(".ff-form__progress-fill");
		const stepLabel = formEl.querySelector(".ff-form__step-label");

		// Conditional logic rules
		const rulesJson = formEl.getAttribute("data-conditional-rules");
		const conditionalRules = rulesJson ? JSON.parse(rulesJson) : {};
		const hasConditionalLogic = Object.keys(conditionalRules).length > 0;

		/**
		 * Evaluate a conditional rule against current form state.
		 * Returns true if the field should be visible.
		 */
		function evaluateCondition(rule) {
			const sourceField = formEl.querySelector('[data-field-id="' + rule.fieldId + '"]');
			if (!sourceField) return true;

			const sourceType = sourceField.getAttribute("data-field-type");
			let sourceValue = "";

			if (sourceType === "checkbox") {
				const cb = sourceField.querySelector('input[type="checkbox"]');
				sourceValue = cb && cb.checked ? "true" : "false";
			} else if (sourceType === "radio") {
				const checked = sourceField.querySelector('input[type="radio"]:checked');
				sourceValue = checked ? checked.value : "";
			} else {
				const input = sourceField.querySelector("input, select, textarea");
				sourceValue = input ? input.value.trim() : "";
			}

			switch (rule.operator) {
				case "equals":
					return sourceValue === rule.value;
				case "not_equals":
					return sourceValue !== rule.value;
				case "contains":
					return sourceValue.toLowerCase().includes((rule.value || "").toLowerCase());
				case "not_empty":
					return sourceValue !== "" && sourceValue !== "false";
				default:
					return true;
			}
		}

		/**
		 * Update visibility of all conditional fields.
		 * Hidden conditional fields are excluded from validation.
		 */
		function updateConditionalVisibility() {
			if (!hasConditionalLogic) return;

			for (const [fieldId, rule] of Object.entries(conditionalRules)) {
				const fieldWrapper = formEl.querySelector('[data-field-id="' + fieldId + '"]');
				if (!fieldWrapper) continue;

				const visible = evaluateCondition(rule);
				fieldWrapper.style.display = visible ? "" : "none";
				fieldWrapper.setAttribute("data-conditionally-hidden", visible ? "false" : "true");

				// Clear errors on hidden fields
				if (!visible) {
					clearFieldError(fieldId);
				}
			}
		}

		/**
		 * Check if a field is conditionally hidden
		 */
		function isConditionallyHidden(fieldWrapper) {
			return fieldWrapper.getAttribute("data-conditionally-hidden") === "true";
		}

		/**
		 * Validate email format
		 */
		function isValidEmail(email) {
			return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
		}

		/**
		 * Validate phone format (7-20 chars of digits, +, -, parens, spaces)
		 */
		function isValidPhone(phone) {
			const cleaned = phone.replace(/[^0-9+\-() ]/g, "");
			return cleaned.length >= 7 && cleaned.length <= 20;
		}

		/**
		 * Show field-level error
		 */
		function showFieldError(fieldId, message) {
			const errorEl = document.getElementById(instanceId + "-" + fieldId + "-error");
			if (errorEl) {
				errorEl.textContent = message;
				errorEl.style.display = "block";
			}
			const inputEl = document.getElementById(instanceId + "-" + fieldId);
			if (inputEl) {
				inputEl.setAttribute("aria-invalid", "true");
				inputEl.classList.add("ff-form__input--error");
			}
		}

		/**
		 * Clear field-level error
		 */
		function clearFieldError(fieldId) {
			const errorEl = document.getElementById(instanceId + "-" + fieldId + "-error");
			if (errorEl) {
				errorEl.textContent = "";
				errorEl.style.display = "none";
			}
			const inputEl = document.getElementById(instanceId + "-" + fieldId);
			if (inputEl) {
				inputEl.removeAttribute("aria-invalid");
				inputEl.classList.remove("ff-form__input--error");
			}
		}

		/**
		 * Clear all field errors
		 */
		function clearAllErrors() {
			const fields = formEl.querySelectorAll("[data-field-id]");
			fields.forEach((field) => {
				clearFieldError(field.getAttribute("data-field-id"));
			});
		}

		/**
		 * Show form-level status message
		 */
		function showStatus(message, isError) {
			if (statusEl) {
				statusEl.textContent = message;
				statusEl.className = "ff-form__status" +
					(isError ? " ff-form__status--error" : "");
				statusEl.style.display = "block";
			}
		}

		/**
		 * Hide form-level status
		 */
		function hideStatus() {
			if (statusEl) {
				statusEl.textContent = "";
				statusEl.style.display = "none";
			}
		}

		/**
		 * Validate a single field wrapper, return true if valid.
		 * Skips conditionally hidden fields.
		 */
		function validateField(fieldWrapper) {
			// Skip conditionally hidden fields — they are not required
			if (isConditionallyHidden(fieldWrapper)) return true;

			const fieldId = fieldWrapper.getAttribute("data-field-id");
			const fieldType = fieldWrapper.getAttribute("data-field-type");
			const isRequired = fieldWrapper.getAttribute("data-field-required") === "true";

			// Hidden fields are never validated client-side
			if (fieldType === "hidden") return true;

			clearFieldError(fieldId);

			let value;
			if (fieldType === "checkbox") {
				const cb = document.getElementById(instanceId + "-" + fieldId);
				value = cb ? cb.checked : false;
			} else if (fieldType === "radio") {
				const checked = fieldWrapper.querySelector('input[type="radio"]:checked');
				value = checked ? checked.value : "";
			} else {
				const inputEl = document.getElementById(instanceId + "-" + fieldId);
				value = inputEl ? inputEl.value.trim() : "";
			}

			const label = fieldWrapper.querySelector("label, legend")?.textContent?.replace("*", "").trim() || "This field";

			// Required check
			if (isRequired) {
				if (fieldType === "checkbox" && !value) {
					showFieldError(fieldId, label + " is required");
					return false;
				} else if (fieldType !== "checkbox" && (value === "" || value === undefined)) {
					showFieldError(fieldId, label + " is required");
					return false;
				}
			}

			// Skip format validation if empty and not required
			if (fieldType !== "checkbox" && (value === "" || value === undefined)) {
				return true;
			}

			// Email format
			if (fieldType === "email" && !isValidEmail(value)) {
				showFieldError(fieldId, "Please enter a valid email address");
				return false;
			}

			// Phone format
			if (fieldType === "phone" && !isValidPhone(value)) {
				showFieldError(fieldId, "Please enter a valid phone number");
				return false;
			}

			// Number range
			if (fieldType === "number") {
				const num = parseFloat(value);
				if (isNaN(num)) {
					showFieldError(fieldId, "Please enter a valid number");
					return false;
				}
				const inputEl = document.getElementById(instanceId + "-" + fieldId);
				const min = inputEl?.getAttribute("min");
				const max = inputEl?.getAttribute("max");
				if (min !== null && min !== "" && num < parseFloat(min)) {
					showFieldError(fieldId, "Value must be at least " + min);
					return false;
				}
				if (max !== null && max !== "" && num > parseFloat(max)) {
					showFieldError(fieldId, "Value must be at most " + max);
					return false;
				}
			}

			return true;
		}

		/**
		 * Validate fields for a specific wizard step.
		 * Returns { valid, firstInvalidId }
		 */
		function validateStep(stepIndex) {
			const stepFieldIds = stepsConfig[stepIndex]?.fieldIds || [];
			let firstInvalidId = null;
			let allValid = true;

			for (const fid of stepFieldIds) {
				const fieldWrapper = formEl.querySelector('[data-field-id="' + fid + '"]');
				if (!fieldWrapper) continue;

				const isValid = validateField(fieldWrapper);
				if (!isValid) {
					if (!firstInvalidId) firstInvalidId = fid;
					allValid = false;
				}
			}

			return { valid: allValid, firstInvalidId };
		}

		/**
		 * Validate all fields, return { valid, data, firstInvalidId }
		 */
		function validateForm() {
			const fields = formEl.querySelectorAll("[data-field-id]");
			const errors = [];
			const data = {};
			let firstInvalidId = null;

			fields.forEach((fieldWrapper) => {
				const fieldId = fieldWrapper.getAttribute("data-field-id");
				const fieldType = fieldWrapper.getAttribute("data-field-type");

				// Skip conditionally hidden fields entirely
				if (isConditionallyHidden(fieldWrapper)) return;

				const isValid = validateField(fieldWrapper);
				if (!isValid) {
					errors.push(fieldId);
					if (!firstInvalidId) firstInvalidId = fieldId;
					return;
				}

				// Collect value
				let value;
				if (fieldType === "checkbox") {
					const cb = document.getElementById(instanceId + "-" + fieldId);
					value = cb ? cb.checked : false;
				} else if (fieldType === "radio") {
					const checked = fieldWrapper.querySelector('input[type="radio"]:checked');
					value = checked ? checked.value : "";
				} else if (fieldType === "hidden") {
					const input = document.getElementById(instanceId + "-" + fieldId);
					value = input ? input.value : "";
				} else {
					const inputEl = document.getElementById(instanceId + "-" + fieldId);
					value = inputEl ? inputEl.value.trim() : "";
				}

				if (fieldType === "checkbox" || fieldType === "hidden" || (value !== "" && value !== undefined)) {
					data[fieldId] = value;
				}
			});

			return { valid: errors.length === 0, data, firstInvalidId };
		}

		/**
		 * Multi-step wizard: show/hide fields for current step.
		 * Data is preserved because we toggle visibility, not destroy elements.
		 */
		function updateStepVisibility() {
			if (!hasSteps) return;

			const allFields = formEl.querySelectorAll("[data-field-id]");
			allFields.forEach((field) => {
				const stepIdx = field.getAttribute("data-step-index");
				if (stepIdx !== null) {
					const isCurrentStep = parseInt(stepIdx, 10) === currentStep;
					// Respect conditional logic: only show if both step matches and condition passes
					if (!isCurrentStep) {
						field.style.display = "none";
					} else {
						const showWhen = field.getAttribute("data-show-when");
						if (showWhen) {
							const rule = JSON.parse(showWhen);
							field.style.display = evaluateCondition(rule) ? "" : "none";
							field.setAttribute("data-conditionally-hidden", evaluateCondition(rule) ? "false" : "true");
						} else {
							field.style.display = "";
						}
					}
				}
			});

			// Update progress indicator
			if (progressText) progressText.textContent = (currentStep + 1).toString();
			if (progressFill) {
				progressFill.style.width = ((currentStep + 1) / totalSteps * 100) + "%";
				progressFill.setAttribute("aria-valuenow", (currentStep + 1).toString());
			}
			if (stepLabel && stepsConfig[currentStep]) {
				stepLabel.textContent = stepsConfig[currentStep].label;
			}

			// Update button visibility
			if (backBtn) backBtn.style.display = currentStep > 0 ? "" : "none";
			if (nextBtn) nextBtn.style.display = currentStep < totalSteps - 1 ? "" : "none";
			if (submitBtn) submitBtn.style.display = currentStep === totalSteps - 1 ? "" : "none";
		}

		// Initialize conditional visibility
		if (hasConditionalLogic) {
			updateConditionalVisibility();
		}

		// Initialize step visibility on load
		if (hasSteps) {
			updateStepVisibility();
		}

		// Listen for input/change events to update conditional visibility
		if (hasConditionalLogic) {
			formEl.addEventListener("input", () => {
				if (hasSteps) {
					updateStepVisibility();
				} else {
					updateConditionalVisibility();
				}
			});
			formEl.addEventListener("change", () => {
				if (hasSteps) {
					updateStepVisibility();
				} else {
					updateConditionalVisibility();
				}
			});
		}

		// Next button: validate current step, then advance
		if (nextBtn) {
			nextBtn.addEventListener("click", () => {
				hideStatus();
				const { valid, firstInvalidId } = validateStep(currentStep);

				if (!valid) {
					if (firstInvalidId) {
						const el = document.getElementById(instanceId + "-" + firstInvalidId);
						if (el) el.focus();
					}
					return;
				}

				currentStep++;
				updateStepVisibility();

				// Focus first visible input of new step for keyboard accessibility
				const newStepFields = stepsConfig[currentStep]?.fieldIds || [];
				if (newStepFields.length > 0) {
					const firstInput = document.getElementById(instanceId + "-" + newStepFields[0]);
					if (firstInput) firstInput.focus();
				}
			});
		}

		// Back button: go to previous step (no validation, data preserved)
		if (backBtn) {
			backBtn.addEventListener("click", () => {
				hideStatus();
				clearAllErrors();
				if (currentStep > 0) {
					currentStep--;
					updateStepVisibility();
				}
			});
		}

		// Clear field error on input
		formEl.addEventListener("input", (e) => {
			const fieldWrapper = e.target.closest("[data-field-id]");
			if (fieldWrapper) {
				clearFieldError(fieldWrapper.getAttribute("data-field-id"));
			}
		});

		// Clear field error on change (for selects, checkboxes, radios)
		formEl.addEventListener("change", (e) => {
			const fieldWrapper = e.target.closest("[data-field-id]");
			if (fieldWrapper) {
				clearFieldError(fieldWrapper.getAttribute("data-field-id"));
			}
		});

		// Form submission
		formEl.addEventListener("submit", async (e) => {
			e.preventDefault();

			clearAllErrors();
			hideStatus();

			// For wizard forms, validate current (final) step first
			if (hasSteps) {
				const { valid: stepValid, firstInvalidId: stepInvalidId } = validateStep(currentStep);
				if (!stepValid) {
					if (stepInvalidId) {
						const el = document.getElementById(instanceId + "-" + stepInvalidId);
						if (el) el.focus();
					}
					return;
				}
			}

			// Full form validation (all steps)
			const { valid, data, firstInvalidId } = validateForm();

			if (!valid) {
				if (firstInvalidId) {
					// If wizard mode, navigate to the step with the invalid field
					if (hasSteps) {
						const fieldWrapper = formEl.querySelector('[data-field-id="' + firstInvalidId + '"]');
						if (fieldWrapper) {
							const stepIdx = parseInt(fieldWrapper.getAttribute("data-step-index") || "0", 10);
							currentStep = stepIdx;
							updateStepVisibility();
						}
					}
					const firstInvalid = document.getElementById(instanceId + "-" + firstInvalidId);
					if (firstInvalid) firstInvalid.focus();
				}
				return;
			}

			// Include honeypot value for server-side rejection
			const hpInput = formEl.querySelector('input[name="_hp"]');
			const honeypot = hpInput ? hpInput.value : "";

			// Disable submit button
			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = "Submitting...";
			}

			try {
				const response = await fetch(submitUrl, {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					credentials: "include",
					body: JSON.stringify({
						formId: formId,
						data: data,
						_hp: honeypot,
					}),
				});

				const result = await response.json();

				if (response.ok && result.success) {
					formEl.style.display = "none";
					if (successEl) {
						successEl.style.display = "block";
					}
				} else {
					// Handle field-level errors from server
					if (result.fieldErrors && typeof result.fieldErrors === "object") {
						let firstErrorField = null;
						for (const [fid, msg] of Object.entries(result.fieldErrors)) {
							showFieldError(fid, msg);
							if (!firstErrorField) firstErrorField = fid;
						}
						if (firstErrorField) {
							const el = document.getElementById(instanceId + "-" + firstErrorField);
							if (el) el.focus();
						}
					} else if (result.details && Array.isArray(result.details)) {
						showStatus(result.details.join(". "), true);
					} else {
						showStatus(result.error || "Submission failed. Please try again.", true);
					}
				}
			} catch (err) {
				showStatus("Network error. Please check your connection and try again.", true);
			} finally {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = submitBtn.getAttribute("data-original-label") || "Submit";
				}
			}
		});

		// Store original submit label for restoration after error
		if (submitBtn) {
			submitBtn.setAttribute("data-original-label", submitBtn.textContent);
		}
	});
</script>

