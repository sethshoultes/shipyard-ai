---
/**
 * SocialPreview.astro
 * Admin-side visual preview of how a page would appear in Google search results
 * and social media shares (Facebook OG card, Twitter card).
 *
 * Props:
 *   - pageSeo: PageSeoData — the full page SEO data object
 *
 * Renders:
 *   - Google SERP preview (title in blue, URL in green, description in gray)
 *   - Facebook share preview card
 *   - Twitter card preview
 */

interface PageSeoData {
	path: string;
	title: string;
	description: string;
	canonicalUrl?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogImage?: string;
	ogType?: string;
	twitterCard?: "summary" | "summary_large_image";
	twitterTitle?: string;
	twitterDescription?: string;
	twitterImage?: string;
}

interface Props {
	pageSeo: PageSeoData;
}

const { pageSeo } = Astro.props;

const ogTitle = pageSeo.ogTitle || pageSeo.title;
const ogDescription = pageSeo.ogDescription || pageSeo.description;
const twTitle = pageSeo.twitterTitle || ogTitle;
const twDescription = pageSeo.twitterDescription || ogDescription;
const twCard = pageSeo.twitterCard || "summary";
const displayUrl = pageSeo.canonicalUrl || `https://example.com${pageSeo.path}`;

function truncate(text: string, max: number): string {
	if (text.length <= max) return text;
	return text.slice(0, max).trimEnd() + "\u2026";
}
---

<div class="social-preview" role="region" aria-label="Social media preview">
	{/* Google SERP Preview */}
	<div class="social-preview__section">
		<h3 class="social-preview__section-title">Google Search Preview</h3>
		<div class="social-preview__serp">
			<div class="social-preview__serp-title">{truncate(pageSeo.title, 60)}</div>
			<div class="social-preview__serp-url">{displayUrl}</div>
			<div class="social-preview__serp-desc">{truncate(pageSeo.description, 160)}</div>
		</div>
	</div>

	{/* Facebook Share Preview */}
	<div class="social-preview__section">
		<h3 class="social-preview__section-title">Facebook Share Preview</h3>
		<div class="social-preview__fb-card">
			{pageSeo.ogImage && (
				<div class="social-preview__fb-image">
					<img src={pageSeo.ogImage} alt="OG preview" loading="lazy" />
				</div>
			)}
			<div class="social-preview__fb-content">
				<div class="social-preview__fb-domain">{new URL(displayUrl).hostname}</div>
				<div class="social-preview__fb-title">{truncate(ogTitle, 65)}</div>
				<div class="social-preview__fb-desc">{truncate(ogDescription, 155)}</div>
			</div>
		</div>
	</div>

	{/* Twitter Card Preview */}
	<div class="social-preview__section">
		<h3 class="social-preview__section-title">Twitter Card Preview</h3>
		<div class={`social-preview__tw-card social-preview__tw-card--${twCard}`}>
			{(pageSeo.twitterImage || pageSeo.ogImage) && (
				<div class="social-preview__tw-image">
					<img src={pageSeo.twitterImage || pageSeo.ogImage} alt="Twitter preview" loading="lazy" />
				</div>
			)}
			<div class="social-preview__tw-content">
				<div class="social-preview__tw-title">{truncate(twTitle, 70)}</div>
				<div class="social-preview__tw-desc">{truncate(twDescription, 125)}</div>
				<div class="social-preview__tw-domain">{new URL(displayUrl).hostname}</div>
			</div>
		</div>
	</div>
</div>

<style>
	.social-preview {
		font-family: var(--font-body, "Source Sans 3", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
		color: var(--color-text, #2C2C2C);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.social-preview__section-title {
		font-family: var(--font-heading, Lora, serif);
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text-secondary, #666);
		margin: 0 0 0.75rem 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.8rem;
	}

	/* Google SERP */
	.social-preview__serp {
		max-width: 600px;
		padding: 1rem;
		background: white;
		border: 1px solid #e5e5e5;
		border-radius: 8px;
	}

	.social-preview__serp-title {
		font-size: 1.2rem;
		color: #1a0dab;
		line-height: 1.3;
		margin-bottom: 0.25rem;
		cursor: pointer;
	}

	.social-preview__serp-title:hover {
		text-decoration: underline;
	}

	.social-preview__serp-url {
		font-size: 0.85rem;
		color: #006621;
		margin-bottom: 0.25rem;
	}

	.social-preview__serp-desc {
		font-size: 0.9rem;
		color: #545454;
		line-height: 1.5;
	}

	/* Facebook */
	.social-preview__fb-card {
		max-width: 500px;
		border: 1px solid #dadde1;
		border-radius: 2px;
		overflow: hidden;
		background: #f2f3f5;
	}

	.social-preview__fb-image img {
		width: 100%;
		height: 260px;
		object-fit: cover;
		display: block;
	}

	.social-preview__fb-content {
		padding: 0.75rem 1rem;
	}

	.social-preview__fb-domain {
		font-size: 0.75rem;
		color: #606770;
		text-transform: uppercase;
		margin-bottom: 0.25rem;
	}

	.social-preview__fb-title {
		font-size: 1rem;
		font-weight: 600;
		color: #1d2129;
		line-height: 1.3;
		margin-bottom: 0.15rem;
	}

	.social-preview__fb-desc {
		font-size: 0.85rem;
		color: #606770;
		line-height: 1.4;
	}

	/* Twitter */
	.social-preview__tw-card {
		max-width: 500px;
		border: 1px solid #e1e8ed;
		border-radius: 14px;
		overflow: hidden;
		background: white;
	}

	.social-preview__tw-image img {
		width: 100%;
		height: 250px;
		object-fit: cover;
		display: block;
	}

	.social-preview__tw-card--summary .social-preview__tw-image img {
		height: 125px;
	}

	.social-preview__tw-content {
		padding: 0.75rem 1rem;
	}

	.social-preview__tw-title {
		font-size: 0.95rem;
		font-weight: 700;
		color: #0f1419;
		line-height: 1.3;
		margin-bottom: 0.15rem;
	}

	.social-preview__tw-desc {
		font-size: 0.85rem;
		color: #536471;
		line-height: 1.4;
		margin-bottom: 0.25rem;
	}

	.social-preview__tw-domain {
		font-size: 0.8rem;
		color: #536471;
	}

	@media (max-width: 640px) {
		.social-preview__serp,
		.social-preview__fb-card,
		.social-preview__tw-card {
			max-width: 100%;
		}
	}
</style>
