# Cloudflare R2 Configuration
#
# Required for uploading theme tarballs to Cloudflare R2 CDN.
# Get these credentials from Cloudflare Dashboard:
# https://dash.cloudflare.com/?to=/:account/r2
#
# Steps to obtain credentials:
# 1. Log in to Cloudflare Dashboard
# 2. Go to R2 > Overview
# 3. Click "Create bucket" or select existing bucket
# 4. Go to Settings > API tokens
# 5. Create new R2 API token with permissions to edit buckets
# 6. Copy the Credentials to below

# Your Cloudflare Account ID (32-character hex string)
# Found in Cloudflare Dashboard URL or R2 Overview
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# R2 API Token - Access Key ID
# Used to authenticate requests to R2
R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 API Token - Secret Access Key
# Used to sign requests to R2
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# Optional: R2 Bucket Name (defaults to "emdash-themes")
# Change only if using a different bucket name
# R2_BUCKET_NAME=emdash-themes
