---
/**
 * Footer Component
 * Displays footer information and links
 */
interface Props {
	title?: string;
	description?: string;
}

const { title = "Slate", description = "Professional, structured, corporate" } = Astro.props;
---

<footer class="slate-footer">
	<div class="slate-footer-content">
		<div class="slate-footer-col">
			<h4>{title}</h4>
			<p>{description}</p>
		</div>
		<div class="slate-footer-col">
			<h4>Resources</h4>
			<ul>
				<li><a href="/">Home</a></li>
				<li><a href="/docs">Documentation</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
	</div>
	<div class="slate-footer-bottom">
		<p>&copy; {new Date().getFullYear()} {title}. All rights reserved.</p>
	</div>
</footer>

<style>
	.slate-footer {
		background: var(--color-surface);
		border-top: 1px solid var(--color-border);
		padding: var(--spacing-12) 0;
		margin-top: var(--spacing-20);
	}

	.slate-footer-content {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6) var(--spacing-12);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
	}

	.slate-footer-col h4 {
		color: var(--color-primary);
		font-size: var(--font-size-sm);
		margin-bottom: var(--spacing-4);
		font-weight: 600;
		letter-spacing: var(--tracking-wide);
	}

	.slate-footer-col p {
		margin: 0;
		color: var(--color-text-secondary);
		font-size: var(--font-size-sm);
	}

	.slate-footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.slate-footer-col li {
		margin-bottom: var(--spacing-2);
	}

	.slate-footer-col a {
		color: var(--color-text-secondary);
		transition: color var(--transition-fast);
		font-size: var(--font-size-sm);
		text-decoration: none;
	}

	.slate-footer-col a:hover {
		color: var(--color-accent);
	}

	.slate-footer-bottom {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-6) var(--spacing-6) 0;
		border-top: 1px solid var(--color-border);
		text-align: center;
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
	}

	@media (max-width: 768px) {
		.slate-footer-content {
			grid-template-columns: 1fr;
		}
	}
</style>
