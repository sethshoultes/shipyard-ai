#!/usr/bin/env bash
# Wardrobe theme marketplace CLI
# Runs the TypeScript CLI via tsx (no build step required)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Use tsx from node_modules or global
if [ -x "$PROJECT_DIR/node_modules/.bin/tsx" ]; then
  TSX="$PROJECT_DIR/node_modules/.bin/tsx"
elif command -v tsx &>/dev/null; then
  TSX="tsx"
else
  echo "Error: tsx not found. Run 'npm install' in $PROJECT_DIR first." >&2
  exit 1
fi

exec "$TSX" "$PROJECT_DIR/cli/index.ts" "$@"
