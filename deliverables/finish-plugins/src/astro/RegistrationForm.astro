---
/**
 * RegistrationForm.astro — Phase 5 Wave 1
 *
 * Public registration form component that renders dynamic form definitions
 * fetched by form ID from the forms API.
 *
 * Features:
 * - Fetches form definition by ID from /membership/forms/:id
 * - Renders all field types: text, email, dropdown, checkbox, phone
 * - Client-side validation: required fields, email format, phone format
 * - Submits to /membership/forms/:id/submit endpoint
 * - Success/error states with confirmation or error messages
 * - Gated content integration: works inside gated-content blocks as upgrade CTA
 * - Accessible: proper labels, ARIA attributes, keyboard navigation
 *
 * Props:
 *   - formId: string (required) — ID of the form definition to render
 *   - heading?: string — optional heading above the form
 *   - submitLabel?: string — custom submit button text (default: "Submit")
 *   - successMessage?: string — custom success message
 *   - compact?: boolean — compact mode for embedding inside gated-content blocks
 */

interface FormFieldDefinition {
	id: string;
	type: "text" | "email" | "dropdown" | "checkbox" | "phone";
	label: string;
	required: boolean;
	options?: string[];
	placeholder?: string;
}

interface FormStep {
	label: string;
	fieldIds: string[];
}

interface FormDefinition {
	id: string;
	name: string;
	description?: string;
	fields: FormFieldDefinition[];
	steps?: FormStep[];
	createdAt: string;
	updatedAt: string;
}

interface Props {
	formId: string;
	heading?: string;
	submitLabel?: string;
	successMessage?: string;
	compact?: boolean;
}

const {
	formId,
	heading,
	submitLabel = "Submit",
	successMessage = "Thank you! Your submission has been received.",
	compact = false,
} = Astro.props;

let form: FormDefinition | null = null;
let error: string | null = null;

// Fetch form definition from API
if (formId) {
	try {
		const response = await fetch(
			new URL(
				`/_emdash/api/plugins/membership/forms/${encodeURIComponent(formId)}`,
				Astro.url.origin
			),
			{ credentials: "include" }
		);

		if (response.ok) {
			const data = (await response.json()) as { form: FormDefinition };
			form = data.form;
		} else if (response.status === 404) {
			error = "This form is no longer available.";
		} else {
			error = "Unable to load the form. Please try again later.";
		}
	} catch (err) {
		console.error("Registration form fetch error:", err);
		error = "Error loading the form. Please try again later.";
	}
} else {
	error = "No form ID provided.";
}

const formTitle = heading || form?.name || "Registration";
const formDescription = form?.description;
// Unique identifier for this form instance (supports multiple forms on one page)
const instanceId = `reg-form-${formId}`;

// Multi-step wizard support
const hasSteps = !!(form?.steps && form.steps.length > 1);
const steps = form?.steps || [];
const totalSteps = steps.length;

// Build a lookup: fieldId -> stepIndex (for wizard mode)
const fieldStepMap: Record<string, number> = {};
if (hasSteps) {
	steps.forEach((step, idx) => {
		step.fieldIds.forEach((fid) => {
			fieldStepMap[fid] = idx;
		});
	});
}
---

<div
	class={`registration-form ${compact ? "registration-form--compact" : ""}`}
	data-form-id={formId}
	id={instanceId}
>
	{error ? (
		<div class="registration-form__error-banner" role="alert" aria-live="polite">
			<p>{error}</p>
		</div>
	) : form ? (
		<>
			<div class="registration-form__header">
				<h2 class="registration-form__title">{formTitle}</h2>
				{formDescription && !compact && (
					<p class="registration-form__description">{formDescription}</p>
				)}
			</div>

			<form
				class="registration-form__form"
				data-form-id={formId}
				data-submit-url={`/_emdash/api/plugins/membership/forms/${encodeURIComponent(formId)}/submit`}
				data-has-steps={hasSteps ? "true" : "false"}
				data-total-steps={totalSteps.toString()}
				data-steps-json={hasSteps ? JSON.stringify(steps) : ""}
				novalidate
				aria-label={formTitle}
			>
				{/* Progress indicator for multi-step forms */}
				{hasSteps && (
					<div class="registration-form__progress" role="navigation" aria-label="Form progress">
						<p class="registration-form__progress-text">
							Step <span data-current-step>1</span> of {totalSteps}
						</p>
						<div class="registration-form__progress-bar">
							<div
								class="registration-form__progress-fill"
								style={`width: ${(1 / totalSteps) * 100}%`}
								role="progressbar"
								aria-valuenow={1}
								aria-valuemin={1}
								aria-valuemax={totalSteps}
							></div>
						</div>
						<p class="registration-form__step-label" aria-live="polite">
							{steps[0].label}
						</p>
					</div>
				)}

				<div class="registration-form__fields">
					{form.fields.map((field) => (
						<div
							class={`registration-form__field registration-form__field--${field.type}`}
							data-field-id={field.id}
							data-field-type={field.type}
							data-field-required={field.required ? "true" : "false"}
							data-step-index={hasSteps && fieldStepMap[field.id] !== undefined ? fieldStepMap[field.id].toString() : undefined}
						>
							{field.type === "checkbox" ? (
								<div class="registration-form__checkbox-wrapper">
									<input
										type="checkbox"
										id={`${instanceId}-${field.id}`}
										name={field.id}
										class="registration-form__checkbox"
										aria-required={field.required ? "true" : undefined}
										aria-describedby={`${instanceId}-${field.id}-error`}
									/>
									<label
										for={`${instanceId}-${field.id}`}
										class="registration-form__checkbox-label"
									>
										{field.label}
										{field.required && (
											<span class="registration-form__required" aria-hidden="true">*</span>
										)}
									</label>
								</div>
							) : (
								<label
									for={`${instanceId}-${field.id}`}
									class="registration-form__label"
								>
									{field.label}
									{field.required && (
										<span class="registration-form__required" aria-hidden="true">*</span>
									)}
								</label>
							)}

							{field.type === "text" && (
								<input
									type="text"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="registration-form__input"
									placeholder={field.placeholder || ""}
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "email" && (
								<input
									type="email"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="registration-form__input"
									placeholder={field.placeholder || "you@example.com"}
									autocomplete="email"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "phone" && (
								<input
									type="tel"
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="registration-form__input"
									placeholder={field.placeholder || "(555) 123-4567"}
									autocomplete="tel"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								/>
							)}

							{field.type === "dropdown" && field.options && (
								<select
									id={`${instanceId}-${field.id}`}
									name={field.id}
									class="registration-form__select"
									aria-required={field.required ? "true" : undefined}
									aria-describedby={`${instanceId}-${field.id}-error`}
								>
									<option value="">{field.placeholder || `Select ${field.label.toLowerCase()}...`}</option>
									{field.options.map((opt) => (
										<option value={opt}>{opt}</option>
									))}
								</select>
							)}

							<p
								class="registration-form__field-error"
								id={`${instanceId}-${field.id}-error`}
								role="alert"
								aria-live="polite"
							></p>
						</div>
					))}
				</div>

				<div class="registration-form__actions">
					{hasSteps && (
						<button
							type="button"
							class="registration-form__back"
							style="display: none;"
							aria-label="Go to previous step"
						>
							Back
						</button>
					)}
					{hasSteps && (
						<button
							type="button"
							class="registration-form__next"
							aria-label="Go to next step"
						>
							Next
						</button>
					)}
					<button
						type="submit"
						class="registration-form__submit"
						style={hasSteps ? "display: none;" : undefined}
					>
						{submitLabel}
					</button>
				</div>

				<div
					class="registration-form__status"
					role="status"
					aria-live="polite"
					style="display: none;"
				></div>
			</form>

			<div
				class="registration-form__success"
				role="status"
				aria-live="polite"
				style="display: none;"
			>
				<div class="registration-form__success-icon" aria-hidden="true">&#10003;</div>
				<p class="registration-form__success-message">{successMessage}</p>
			</div>
		</>
	) : (
		<div class="registration-form__loading" role="status" aria-live="polite">
			<p>Loading form...</p>
		</div>
	)}
</div>

<script define:vars={{ instanceId, formId }}>
	document.addEventListener("DOMContentLoaded", () => {
		const container = document.getElementById(instanceId);
		if (!container) return;

		const formEl = container.querySelector("form[data-form-id]");
		if (!formEl) return;

		const submitUrl = formEl.getAttribute("data-submit-url");
		const successEl = container.querySelector(".registration-form__success");
		const statusEl = container.querySelector(".registration-form__status");
		const submitBtn = formEl.querySelector(".registration-form__submit");

		// Multi-step wizard state
		const hasSteps = formEl.getAttribute("data-has-steps") === "true";
		const totalSteps = parseInt(formEl.getAttribute("data-total-steps") || "0", 10);
		const stepsJson = formEl.getAttribute("data-steps-json");
		const stepsConfig = stepsJson ? JSON.parse(stepsJson) : [];
		let currentStep = 0;

		const backBtn = formEl.querySelector(".registration-form__back");
		const nextBtn = formEl.querySelector(".registration-form__next");
		const progressText = formEl.querySelector("[data-current-step]");
		const progressFill = formEl.querySelector(".registration-form__progress-fill");
		const stepLabel = formEl.querySelector(".registration-form__step-label");

		/**
		 * Validate email format
		 */
		function isValidEmail(email) {
			return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
		}

		/**
		 * Validate phone format (7-20 chars of digits, +, -, parens, spaces)
		 */
		function isValidPhone(phone) {
			const cleaned = phone.replace(/[^0-9+\-() ]/g, "");
			return cleaned.length >= 7 && cleaned.length <= 20;
		}

		/**
		 * Show field-level error
		 */
		function showFieldError(fieldId, message) {
			const errorEl = document.getElementById(instanceId + "-" + fieldId + "-error");
			if (errorEl) {
				errorEl.textContent = message;
				errorEl.style.display = "block";
			}
			const inputEl = document.getElementById(instanceId + "-" + fieldId);
			if (inputEl) {
				inputEl.setAttribute("aria-invalid", "true");
				inputEl.classList.add("registration-form__input--error");
			}
		}

		/**
		 * Clear field-level error
		 */
		function clearFieldError(fieldId) {
			const errorEl = document.getElementById(instanceId + "-" + fieldId + "-error");
			if (errorEl) {
				errorEl.textContent = "";
				errorEl.style.display = "none";
			}
			const inputEl = document.getElementById(instanceId + "-" + fieldId);
			if (inputEl) {
				inputEl.removeAttribute("aria-invalid");
				inputEl.classList.remove("registration-form__input--error");
			}
		}

		/**
		 * Clear all field errors
		 */
		function clearAllErrors() {
			const fields = formEl.querySelectorAll("[data-field-id]");
			fields.forEach((field) => {
				clearFieldError(field.getAttribute("data-field-id"));
			});
		}

		/**
		 * Show form-level status message
		 */
		function showStatus(message, isError) {
			if (statusEl) {
				statusEl.textContent = message;
				statusEl.className = "registration-form__status" +
					(isError ? " registration-form__status--error" : "");
				statusEl.style.display = "block";
			}
		}

		/**
		 * Hide form-level status
		 */
		function hideStatus() {
			if (statusEl) {
				statusEl.textContent = "";
				statusEl.style.display = "none";
			}
		}

		/**
		 * Validate a single field wrapper, return true if valid
		 */
		function validateField(fieldWrapper) {
			const fieldId = fieldWrapper.getAttribute("data-field-id");
			const fieldType = fieldWrapper.getAttribute("data-field-type");
			const isRequired = fieldWrapper.getAttribute("data-field-required") === "true";
			const inputEl = document.getElementById(instanceId + "-" + fieldId);

			if (!inputEl) return true;

			let value;
			if (fieldType === "checkbox") {
				value = inputEl.checked;
			} else {
				value = inputEl.value.trim();
			}

			clearFieldError(fieldId);

			if (isRequired) {
				if (fieldType === "checkbox" && !value) {
					const label = fieldWrapper.querySelector("label")?.textContent?.replace("*", "").trim() || "This field";
					showFieldError(fieldId, label + " is required");
					return false;
				} else if (fieldType !== "checkbox" && (value === "" || value === undefined)) {
					const label = fieldWrapper.querySelector("label")?.textContent?.replace("*", "").trim() || "This field";
					showFieldError(fieldId, label + " is required");
					return false;
				}
			}

			if (fieldType !== "checkbox" && (value === "" || value === undefined)) {
				return true;
			}

			if (fieldType === "email" && !isValidEmail(value)) {
				showFieldError(fieldId, "Please enter a valid email address");
				return false;
			}

			if (fieldType === "phone" && !isValidPhone(value)) {
				showFieldError(fieldId, "Please enter a valid phone number");
				return false;
			}

			return true;
		}

		/**
		 * Validate fields for a specific wizard step.
		 * Returns { valid, firstInvalidId }
		 */
		function validateStep(stepIndex) {
			const stepFieldIds = stepsConfig[stepIndex]?.fieldIds || [];
			let firstInvalidId = null;
			let allValid = true;

			for (const fid of stepFieldIds) {
				const fieldWrapper = formEl.querySelector('[data-field-id="' + fid + '"]');
				if (!fieldWrapper) continue;

				const isValid = validateField(fieldWrapper);
				if (!isValid) {
					if (!firstInvalidId) firstInvalidId = fid;
					allValid = false;
				}
			}

			return { valid: allValid, firstInvalidId };
		}

		/**
		 * Validate all fields, return { valid, data, firstInvalidId }
		 */
		function validateForm() {
			const fields = formEl.querySelectorAll("[data-field-id]");
			const errors = [];
			const data = {};
			let firstInvalidId = null;

			fields.forEach((fieldWrapper) => {
				const fieldId = fieldWrapper.getAttribute("data-field-id");
				const fieldType = fieldWrapper.getAttribute("data-field-type");
				const inputEl = document.getElementById(instanceId + "-" + fieldId);

				if (!inputEl) return;

				const isValid = validateField(fieldWrapper);
				if (!isValid) {
					errors.push(fieldId);
					if (!firstInvalidId) firstInvalidId = fieldId;
					return;
				}

				let value;
				if (fieldType === "checkbox") {
					value = inputEl.checked;
				} else {
					value = inputEl.value.trim();
				}

				if (fieldType === "checkbox" || (value !== "" && value !== undefined)) {
					data[fieldId] = value;
				}
			});

			return { valid: errors.length === 0, data, firstInvalidId };
		}

		/**
		 * Multi-step wizard: show/hide fields for current step.
		 * Data is preserved because we toggle visibility, not destroy elements.
		 */
		function updateStepVisibility() {
			if (!hasSteps) return;

			const allFields = formEl.querySelectorAll("[data-field-id]");
			allFields.forEach((field) => {
				const stepIdx = field.getAttribute("data-step-index");
				if (stepIdx !== null) {
					field.style.display = parseInt(stepIdx, 10) === currentStep ? "" : "none";
				}
			});

			// Update progress indicator
			if (progressText) progressText.textContent = (currentStep + 1).toString();
			if (progressFill) {
				progressFill.style.width = ((currentStep + 1) / totalSteps * 100) + "%";
				progressFill.setAttribute("aria-valuenow", (currentStep + 1).toString());
			}
			if (stepLabel && stepsConfig[currentStep]) {
				stepLabel.textContent = stepsConfig[currentStep].label;
			}

			// Update button visibility
			if (backBtn) backBtn.style.display = currentStep > 0 ? "" : "none";
			if (nextBtn) nextBtn.style.display = currentStep < totalSteps - 1 ? "" : "none";
			if (submitBtn) submitBtn.style.display = currentStep === totalSteps - 1 ? "" : "none";
		}

		// Initialize step visibility on load
		if (hasSteps) {
			updateStepVisibility();
		}

		// Next button: validate current step, then advance
		if (nextBtn) {
			nextBtn.addEventListener("click", () => {
				hideStatus();
				const { valid, firstInvalidId } = validateStep(currentStep);

				if (!valid) {
					if (firstInvalidId) {
						const el = document.getElementById(instanceId + "-" + firstInvalidId);
						if (el) el.focus();
					}
					return;
				}

				currentStep++;
				updateStepVisibility();

				// Focus first visible input of new step for keyboard accessibility
				const newStepFields = stepsConfig[currentStep]?.fieldIds || [];
				if (newStepFields.length > 0) {
					const firstInput = document.getElementById(instanceId + "-" + newStepFields[0]);
					if (firstInput) firstInput.focus();
				}
			});
		}

		// Back button: go to previous step (no validation, data preserved)
		if (backBtn) {
			backBtn.addEventListener("click", () => {
				hideStatus();
				clearAllErrors();
				if (currentStep > 0) {
					currentStep--;
					updateStepVisibility();
				}
			});
		}

		// Clear field error on input
		formEl.addEventListener("input", (e) => {
			const fieldWrapper = e.target.closest("[data-field-id]");
			if (fieldWrapper) {
				clearFieldError(fieldWrapper.getAttribute("data-field-id"));
			}
		});

		// Clear field error on change (for selects and checkboxes)
		formEl.addEventListener("change", (e) => {
			const fieldWrapper = e.target.closest("[data-field-id]");
			if (fieldWrapper) {
				clearFieldError(fieldWrapper.getAttribute("data-field-id"));
			}
		});

		// Form submission
		formEl.addEventListener("submit", async (e) => {
			e.preventDefault();

			clearAllErrors();
			hideStatus();

			// For wizard forms, validate current (final) step first
			if (hasSteps) {
				const { valid: stepValid, firstInvalidId: stepInvalidId } = validateStep(currentStep);
				if (!stepValid) {
					if (stepInvalidId) {
						const el = document.getElementById(instanceId + "-" + stepInvalidId);
						if (el) el.focus();
					}
					return;
				}
			}

			// Full form validation (all steps)
			const { valid, data, firstInvalidId } = validateForm();

			if (!valid) {
				if (firstInvalidId) {
					// If wizard mode, navigate to the step with the invalid field
					if (hasSteps) {
						const fieldWrapper = formEl.querySelector('[data-field-id="' + firstInvalidId + '"]');
						if (fieldWrapper) {
							const stepIdx = parseInt(fieldWrapper.getAttribute("data-step-index") || "0", 10);
							currentStep = stepIdx;
							updateStepVisibility();
						}
					}
					const firstInvalid = document.getElementById(instanceId + "-" + firstInvalidId);
					if (firstInvalid) firstInvalid.focus();
				}
				return;
			}

			// Disable submit button
			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.textContent = "Submitting...";
			}

			try {
				const response = await fetch(submitUrl, {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					credentials: "include",
					body: JSON.stringify({ data }),
				});

				const result = await response.json();

				if (response.ok && result.success) {
					formEl.style.display = "none";
					if (successEl) {
						successEl.style.display = "block";
					}
				} else {
					if (result.details && Array.isArray(result.details)) {
						showStatus(result.details.join(". "), true);
					} else {
						showStatus(result.error || "Submission failed. Please try again.", true);
					}
				}
			} catch (err) {
				showStatus("Network error. Please check your connection and try again.", true);
			} finally {
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.textContent = submitBtn.getAttribute("data-original-label") || "Submit";
				}
			}
		});

		// Store original submit label for restoration after error
		if (submitBtn) {
			submitBtn.setAttribute("data-original-label", submitBtn.textContent);
		}
	});
</script>

<style>
	.registration-form {
		font-family: "Source Sans 3", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: #2c2c2c;
		line-height: 1.6;
	}

	.registration-form__header {
		margin-bottom: 1.5rem;
	}

	.registration-form__title {
		margin: 0 0 0.5rem 0;
		font-size: 1.5rem;
		color: #2c2c2c;
		font-family: Lora, serif;
		font-weight: 600;
	}

	.registration-form__description {
		margin: 0;
		font-size: 0.95rem;
		color: #666;
	}

	/* Fields */
	.registration-form__fields {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.registration-form__field {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.registration-form__label {
		font-size: 0.9rem;
		font-weight: 600;
		color: #2c2c2c;
	}

	.registration-form__required {
		color: #c62828;
		margin-left: 0.25rem;
	}

	/* Inputs */
	.registration-form__input,
	.registration-form__select {
		padding: 0.75rem;
		min-height: 44px;
		border: 1px solid #d4c4b5;
		border-radius: 0.25rem;
		font-size: 0.95rem;
		font-family: inherit;
		color: #2c2c2c;
		background-color: white;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.registration-form__input:focus,
	.registration-form__select:focus {
		outline: none;
		border-color: #c4704b;
		box-shadow: 0 0 0 3px rgba(196, 112, 75, 0.15);
	}

	.registration-form__input:focus-visible,
	.registration-form__select:focus-visible {
		outline: 3px solid #d4a853;
		outline-offset: 2px;
	}

	.registration-form__input--error,
	.registration-form__select--error {
		border-color: #c62828;
