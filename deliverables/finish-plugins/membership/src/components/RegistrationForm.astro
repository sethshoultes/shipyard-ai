---
/**
 * RegistrationForm Component
 * Version: 1.0.0
 *
 * Single-form registration: email only. No password maze.
 * Redirects to Stripe Checkout for payment.
 *
 * Brand voice: terse, warm, confident.
 */

interface Plan {
  id: string;
  priceId: string;
  name: string;
  price: string;
  interval: 'month' | 'year';
  features?: string[];
  popular?: boolean;
}

interface Props {
  plans: Plan[];
  title?: string;
  subtitle?: string;
  apiEndpoint?: string;
}

const {
  plans,
  title = 'Join us',
  subtitle = 'Unlock everything. One subscription.',
  apiEndpoint = '/api/membership/checkout',
} = Astro.props;
---

<div class="registration-form-container">
  <div class="form-header">
    <h2 class="form-title">{title}</h2>
    <p class="form-subtitle">{subtitle}</p>
  </div>

  <form class="registration-form" id="registration-form" data-endpoint={apiEndpoint}>
    <div class="form-field">
      <label for="email" class="field-label">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@example.com"
        class="field-input"
        autocomplete="email"
      />
    </div>

    <div class="plan-selector">
      <label class="field-label">Choose your plan</label>
      <div class="plan-options">
        {plans.map((plan, index) => (
          <label class={`plan-option ${plan.popular ? 'popular' : ''}`}>
            <input
              type="radio"
              name="priceId"
              value={plan.priceId}
              required
              checked={index === 0}
            />
            <div class="plan-content">
              {plan.popular && <span class="popular-badge">Popular</span>}
              <span class="plan-name">{plan.name}</span>
              <span class="plan-price">
                {plan.price}<span class="plan-interval">/{plan.interval}</span>
              </span>
              {plan.features && plan.features.length > 0 && (
                <ul class="plan-features">
                  {plan.features.map((feature) => (
                    <li>{feature}</li>
                  ))}
                </ul>
              )}
            </div>
          </label>
        ))}
      </div>
    </div>

    <button type="submit" class="submit-btn" id="submit-btn">
      <span class="btn-text">Continue to payment</span>
      <span class="btn-loading" style="display: none;">
        <svg class="spinner" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
        </svg>
      </span>
    </button>

    <p class="form-note">
      You'll be redirected to Stripe to complete payment securely.
    </p>

    <div class="form-error" id="form-error" style="display: none;"></div>
  </form>
</div>

<script>
  const form = document.getElementById('registration-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = submitBtn?.querySelector('.btn-text') as HTMLElement;
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLElement;
  const errorDiv = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline-flex';
    errorDiv.style.display = 'none';

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const priceId = formData.get('priceId') as string;
    const endpoint = form.dataset.endpoint || '/api/membership/checkout';

    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, priceId }),
      });

      const data = await response.json();

      if (data.success && data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error || 'Something went wrong');
      }
    } catch (error) {
      // Show error with compassionate message
      errorDiv.textContent = error instanceof Error
        ? error.message
        : 'Something went wrong. Please try again.';
      errorDiv.style.display = 'block';

      // Reset button
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>

<style>
  .registration-form-container {
    max-width: 480px;
    margin: 0 auto;
    padding: 2rem;
  }

  .form-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .form-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin: 0 0 0.5rem;
  }

  .form-subtitle {
    font-size: 1rem;
    color: var(--color-muted, #6b7280);
    margin: 0;
  }

  .registration-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text, #111827);
  }

  .field-input {
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    background: var(--color-bg, white);
    color: var(--color-text, #111827);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-primary, #4f46e5);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
  }

  .plan-selector {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .plan-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .plan-option {
    position: relative;
    cursor: pointer;
  }

  .plan-option input {
    position: absolute;
    opacity: 0;
  }

  .plan-content {
    padding: 1rem;
    border: 2px solid var(--color-border, #e5e7eb);
    border-radius: 10px;
    transition: all 0.15s ease;
  }

  .plan-option input:checked + .plan-content {
    border-color: var(--color-primary, #4f46e5);
    background: rgba(79, 70, 229, 0.05);
  }

  .plan-option:hover .plan-content {
    border-color: var(--color-primary, #4f46e5);
  }

  .plan-option.popular .plan-content {
    border-color: var(--color-primary, #4f46e5);
  }

  .popular-badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    color: white;
    background: var(--color-primary, #4f46e5);
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .plan-name {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text, #111827);
  }

  .plan-price {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin-top: 0.25rem;
  }

  .plan-interval {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-muted, #6b7280);
  }

  .plan-features {
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
    font-size: 0.8125rem;
    color: var(--color-muted, #6b7280);
  }

  .plan-features li {
    padding: 0.25rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .plan-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary, #4f46e5);
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: white;
    background: var(--color-primary, #4f46e5);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .submit-btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .submit-btn:disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .spinner {
    width: 20px;
    height: 20px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .form-note {
    font-size: 0.8125rem;
    color: var(--color-muted, #6b7280);
    text-align: center;
    margin: 0;
  }

  .form-error {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #991b1b;
    background: #fee2e2;
    border-radius: 8px;
    text-align: center;
  }
</style>
