---
/**
 * Ember Theme - Base Layout
 * Magazine-style with dark navy + burnt orange
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Bold. Editorial. For people with something to say.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+Pro:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --color-primary: #1a2744;
        --color-accent: #d4622a;
        --color-background: #0f172a;
        --color-surface: #1e293b;
        --color-text: #f8fafc;
        --color-muted: #94a3b8;
        --font-heading: 'Playfair Display', Georgia, serif;
        --font-body: 'Source Sans Pro', system-ui, sans-serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        background-color: var(--color-background);
        color: var(--color-text);
        line-height: 1.6;
        min-height: 100vh;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 600;
        line-height: 1.2;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.2s ease;
      }

      a:hover {
        color: #e8814a;
      }

      .container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav class="nav">
          <a href="/" class="logo">Ember</a>
          <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/posts">Posts</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Ember Theme. Powered by Emdash.</p>
      </div>
    </footer>

    <style>
      .site-header {
        background: var(--color-surface);
        border-bottom: 3px solid var(--color-accent);
        padding: 1rem 0;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--color-text);
      }

      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--color-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.875rem;
      }

      .nav-links a:hover {
        color: var(--color-accent);
      }

      main {
        min-height: calc(100vh - 200px);
      }

      .site-footer {
        background: var(--color-surface);
        padding: 2rem 0;
        margin-top: 4rem;
        text-align: center;
        color: var(--color-muted);
      }

      @media (max-width: 768px) {
        .nav {
          flex-direction: column;
          gap: 1rem;
        }

        .nav-links {
          gap: 1rem;
        }
      }
    </style>
  </body>
</html>
