# LocalGenius Engagement System (Pulse) - Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/localgenius

# Email Service (Resend)
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# Image Storage (S3 or Cloudflare R2)
S3_BUCKET_NAME=localgenius-badge-images
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key_here
S3_SECRET_ACCESS_KEY=your_secret_key_here
S3_ENDPOINT=https://your-bucket.s3.amazonaws.com

# CDN Configuration
CDN_URL=https://cdn.localgenius.com

# Application Settings
NODE_ENV=development
APP_URL=https://app.localgenius.com

# Monitoring & Alerts
SENTRY_DSN=https://your_sentry_dsn_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Rate Limiting & Costs
MAX_SMS_PER_USER_PER_DAY=5
SMS_COST_PER_MESSAGE=0.03
NOTIFICATION_QUEUE_ALERT_THRESHOLD=1000

# Feature Flags
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_BADGE_SYSTEM=true
ENABLE_JOURNAL_PROMPTS=true
ENABLE_CLIFFHANGER=true
