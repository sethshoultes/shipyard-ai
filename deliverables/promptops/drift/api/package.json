{
  "name": "drift-api",
  "version": "1.0.0",
  "description": "Drift API - Git for your AI prompts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create drift",
    "db:migrate": "wrangler d1 execute drift --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute drift --local --file=./src/db/schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240320.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.40.0"
  }
}
